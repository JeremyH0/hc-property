---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

import { Image } from 'astro:assets';

// ==========================================
// IMAGE IMPORTS
// ==========================================

// Hero
import imgHeroHQ from '../assets/gallery/hero-hq.jpg';

// Concept Section (Crossfades)
import imgSuite from '../assets/gallery/suite.jpeg';
import imgSuite2 from '../assets/gallery/suite2.jpeg';
import imgFirepit from '../assets/gallery/firepit1.jpeg'; 

// Floorplans
import imgFloorplan1 from '../assets/gallery/floorplan1.jpeg';
import imgFloorplan2 from '../assets/gallery/floorplan2.jpeg';
import imgFloorplan1HD from '../assets/gallery/floorplan1hd.jpeg';
import imgFloorplan2HD from '../assets/gallery/floorplan2hd.jpeg';

// 16-Image Gallery
import img1 from '../assets/gallery/1.jpeg';
import img2 from '../assets/gallery/2.jpeg';
import img3 from '../assets/gallery/3.jpeg';
import img4 from '../assets/gallery/4.jpeg';
import img5 from '../assets/gallery/5.jpeg';
import img6 from '../assets/gallery/6.jpeg';
import img7 from '../assets/gallery/7.jpeg';
import img8 from '../assets/gallery/8.jpeg';
import img9 from '../assets/gallery/9.jpeg';
import img10 from '../assets/gallery/10.jpeg';
import img11 from '../assets/gallery/11.jpeg';
import img12 from '../assets/gallery/12.jpeg';
import img13 from '../assets/gallery/13.jpeg';
import img14 from '../assets/gallery/14.jpeg';
import img15 from '../assets/gallery/15.jpeg';
import img16 from '../assets/gallery/16.jpeg';

// Array for mapping the gallery grid/carousel
const galleryImages = [
    { src: img1, label: "Image 1" }, { src: img2, label: "Image 2" },
    { src: img3, label: "Image 3" }, { src: img4, label: "Image 4" },
    { src: img5, label: "Image 5" }, { src: img6, label: "Image 6" },
    { src: img7, label: "Image 7" }, { src: img8, label: "Image 8" },
    { src: img9, label: "Image 9" }, { src: img10, label: "Image 10" },
    { src: img11, label: "Image 11" }, { src: img12, label: "Image 12" },
    { src: img13, label: "Image 13" }, { src: img14, label: "Image 14" },
    { src: img15, label: "Image 15" }, { src: img16, label: "Image 16" }
];
---

<Layout title="Karuizawa | HIrafu Capital GK">
    <Navigation />
    
    <main class="w-full tracking-normal leading-loose">
        
        <!-- ========================================== -->
        <!-- HERO SECTION                               -->
        <!-- ========================================== -->
        <section id="hero-section" class="relative w-full h-[35svh] min-h-[320px] md:h-[35svh] md:min-h-[400px] lg:h-[100svh] lg:min-h-[700px] flex flex-col overflow-hidden bg-zinc-950">
            
            <div class="absolute inset-0 w-full h-full">
                <Image 
                    src={imgHeroHQ} 
                    alt="Exterior view of Seren Collective Maple" 
                    widths={[768, 1280, 1920, 2560]}
                    sizes="100vw"
                    class="w-full h-full object-cover opacity-90" 
                    loading="eager" 
                    fetchpriority="high" 
                />
                <!-- Avoided pure black: using zinc-950 and zinc-900 -->
                <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/80 md:from-zinc-950/60 lg:from-zinc-950/50 via-transparent to-zinc-900/40"></div>
            </div>

            <div class="relative z-10 flex flex-col items-start justify-end text-left px-6 md:px-12 w-full max-w-[100rem] mx-auto h-full pb-8 md:pb-12 lg:pb-32">
                <h1 class="hero-reveal font-sans text-2xl md:text-3xl lg:text-5xl font-light tracking-[0.15em] text-white drop-shadow-sm flex items-center">
                    Karuizawa <span class="mx-3 md:mx-4 font-extralight text-white/50 text-xl md:text-2xl lg:text-4xl">|</span> 軽井沢
                </h1>
            </div>

            <div class="hidden xl:flex absolute bottom-12 right-12 z-10 hero-reveal flex-col items-center gap-4">
                <span class="font-sans text-[9px] tracking-[0.3em] uppercase text-white/60" style="writing-mode: vertical-rl;">Scroll</span>
                <div class="w-px h-12 bg-white/20 relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-1/2 bg-white animate-scroll-drop"></div>
                </div>
            </div>
        </section>

        <!-- ========================================== -->
        <!-- CONCEPT SECTION                            -->
        <!-- ========================================== -->
        <section id="concept" class="px-6 py-24 md:py-32 lg:py-48 max-w-4xl mx-auto text-center">
            <span class="reveal-el font-sans text-xs font-medium tracking-widest uppercase text-zinc-400 mb-8 block">The Estate</span>
            <h2 class="reveal-el font-serif text-3xl md:text-5xl lg:text-6xl font-light text-zinc-800 tracking-wide mb-12 md:mb-16 leading-tight">
                A sanctuary divided, <br class="hidden md:block"/> yet perfectly unified.
            </h2>
            <div class="reveal-el font-sans text-zinc-500 font-light leading-loose flex flex-col gap-6 md:gap-8 text-left md:text-center text-sm md:text-base lg:text-lg max-w-3xl mx-auto">
                <p>Set within a deeply forested enclave of Karuizawa, this remarkable residence is ingeniously designed as two distinct structures—a main house and a guest house—connected seamlessly by an elegant hallway.</p>
                <p>This intelligent layout allows the property to function flawlessly as a single, grand estate for large gatherings, or it can be secured to provide absolute privacy and independence for both hosts and guests.</p>
            </div>
        </section>

        <!-- ========================================== -->
        <!-- ARCHITECTURE & AMENITIES                   -->
        <!-- ========================================== -->
        <section id="architecture" class="px-6 md:px-12 py-16 md:py-24 lg:py-32 max-w-[100rem] mx-auto">
            <div class="grid grid-cols-1 xl:grid-cols-2 gap-12 xl:gap-24 items-center">
                
                <div class="reveal-el flex flex-col gap-4 md:gap-6 xl:px-8 order-1">
                    <span class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400">Accommodations</span>
                    <h3 class="font-serif text-2xl md:text-3xl lg:text-4xl font-light text-zinc-800">Seven Private Suites</h3>
                    <p class="font-sans text-sm md:text-base text-zinc-500 font-light leading-loose">The estate accommodates family and guests with uncompromising comfort. The main residence features four spacious bedrooms, while the guest house offers three. Crucially, every single bedroom in the estate is complemented by its own private ensuite bathroom.</p>
                </div>
                
                <!-- Suite Crossfade Container -->
                <div class="reveal-el w-full aspect-[4/3] bg-zinc-50 overflow-hidden rounded-xl border border-zinc-200 order-2 relative scroll-crossfade">
                    <Image src={imgSuite} alt="Private Suite Interior Day" class="w-full h-full object-cover absolute inset-0 z-0" />
                    <!-- Hardware accelerated via transform-gpu and will-change-opacity -->
                    <Image src={imgSuite2} alt="Private Suite Interior Night" class="w-full h-full object-cover absolute inset-0 z-10 crossfade-target opacity-0 pointer-events-none transition-none will-change-opacity transform-gpu" />
                </div>

                <div class="reveal-el flex flex-col gap-4 md:gap-6 xl:px-8 order-3 xl:order-4">
                    <span class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400">Wellness & Leisure</span>
                    <h3 class="font-serif text-2xl md:text-3xl lg:text-4xl font-light text-zinc-800">Private Spa & Firepit</h3>
                    <p class="font-sans text-sm md:text-base text-zinc-500 font-light leading-loose">The second floor of the main house is dedicated to wellness, featuring a private spa with dual large soaking tubs and a custom sauna. Outside, a generous wooden deck centers around a sunken firepit—the perfect setting for evening relaxation under the forest canopy.</p>
                </div>
                
                <!-- Single Firepit Container -->
                <div class="reveal-el w-full aspect-[4/3] bg-zinc-50 overflow-hidden rounded-xl border border-zinc-200 order-4 xl:order-3">
                    <Image src={imgFirepit} alt="Wellness and Deck Firepit" class="w-full h-full object-cover" />
                </div>

            </div>
        </section>

        <!-- ========================================== -->
        <!-- FLOORPLAN SECTION                          -->
        <!-- ========================================== -->
        <section id="floorplan" class="px-6 md:px-12 py-24 md:py-32 lg:py-40 max-w-[100rem] mx-auto border-t border-zinc-200">
            <div class="grid grid-cols-1 xl:grid-cols-12 gap-12 xl:gap-24 relative items-start">
                
                <div class="xl:col-span-4 xl:sticky xl:top-32 transition-all duration-300">
                    <div class="reveal-el flex flex-col gap-6 md:gap-8">
                        <div>
                            <span class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400 mb-4 block">The Masterplan</span>
                            <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-light text-zinc-800 tracking-wide">Structural Harmony.</h2>
                        </div>
                        <div class="flex flex-col gap-4 md:gap-6 font-sans text-sm md:text-base text-zinc-500 font-light leading-loose">
                            <p>The first floor establishes the estate's dual-wing concept. A central gallery bridges the main residence and the guest house, wrapping around a landscaped garden and a sweeping outdoor terrace.</p>
                            <p>The second floor is dedicated entirely to privacy and wellness. It houses the seven ensuite bedrooms, alongside the main house's dedicated spa and sauna retreat.</p>
                        </div>
                    </div>
                </div>

                <div class="xl:col-span-8 flex flex-col gap-12 md:gap-16 lg:gap-24">
                    
                    <div class="reveal-el flex flex-col gap-6">
                        <button class="floorplan-trigger group w-full bg-zinc-50 p-4 md:p-8 lg:p-12 rounded-xl flex items-center justify-center border border-zinc-200 relative overflow-hidden cursor-pointer" data-index="0" data-hd-src={imgFloorplan1HD.src} data-caption="First Floor: Living & Gathering Spaces">
                            <Image src={imgFloorplan1} alt="First Floor Plan" class="w-full h-auto object-contain mix-blend-multiply opacity-80 transition-transform duration-700 ease-out group-hover:scale-105" />
                            
                            <div class="absolute inset-0 bg-white/10 backdrop-blur-[1px] opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center pointer-events-none">
                                <span class="font-sans text-[10px] md:text-xs font-medium tracking-widest uppercase text-zinc-800 border border-zinc-800 px-6 py-3 rounded-full bg-white/90">View Floorplan</span>
                            </div>
                        </button>
                        <span class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400 text-center xl:text-left">
                            First Floor: Living & Gathering Spaces
                        </span>
                    </div>
                    
                    <div class="reveal-el flex flex-col gap-6">
                        <button class="floorplan-trigger group w-full bg-zinc-50 p-4 md:p-8 lg:p-12 rounded-xl flex items-center justify-center border border-zinc-200 relative overflow-hidden cursor-pointer" data-index="1" data-hd-src={imgFloorplan2HD.src} data-caption="Second Floor: Private Suites & Spa">
                            <Image src={imgFloorplan2} alt="Second Floor Plan" class="w-full h-auto object-contain mix-blend-multiply opacity-80 transition-transform duration-700 ease-out group-hover:scale-105" />
                            
                            <div class="absolute inset-0 bg-white/10 backdrop-blur-[1px] opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center pointer-events-none">
                                <span class="font-sans text-[10px] md:text-xs font-medium tracking-widest uppercase text-zinc-800 border border-zinc-800 px-6 py-3 rounded-full bg-white/90">View Floorplan</span>
                            </div>
                        </button>
                        <span class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400 text-center xl:text-left">
                            Second Floor: Private Suites & Spa
                        </span>
                    </div>

                </div>

            </div>
        </section>

        <!-- ========================================== -->
        <!-- IMAGE GALLERY                              -->
        <!-- ========================================== -->
        <section id="gallery" class="px-6 md:px-12 py-24 md:py-32 lg:py-40 max-w-[100rem] mx-auto border-t border-zinc-200 relative">
            
            <div class="reveal-el mb-8 md:mb-12 lg:mb-20">
                <span class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400 mb-6 block">The Gallery</span>
            </div>

            <div class="reveal-el grid grid-cols-1 xl:grid-cols-12 gap-4 md:gap-6 xl:gap-12 items-stretch w-full">
                
                <!-- Main Featured Image -->
                <div id="main-gallery-container" class="xl:col-span-7 w-full relative aspect-[4/3] xl:aspect-[3/2] bg-zinc-50 overflow-hidden rounded-xl border border-zinc-200">
                    <img id="main-gallery-image" src={img1.src} alt="Gallery Image" class="w-full h-full object-cover xl:absolute xl:inset-0 transition-opacity duration-300 ease-in-out opacity-100 select-none" loading="lazy" decoding="async"/>
                    
                    <!-- Mobile Swipe Indicator -->
                    <div id="swipe-indicator" class="xl:hidden absolute bottom-4 md:bottom-6 left-1/2 -translate-x-1/2 z-20 pointer-events-none transition-opacity duration-500">
                        <span class="inline-block bg-zinc-900/60 backdrop-blur-sm text-white px-4 py-2 rounded-full font-sans text-[9px] font-medium tracking-widest uppercase">
                            ← Swipe →
                        </span>
                    </div>
                </div>

                <!-- Mobile Thumbnail Track -->
                <div class="xl:hidden w-full relative carousel-blur overflow-hidden">
                    <div id="mobile-thumb-scroll" class="flex gap-2 md:gap-3 overflow-x-auto snap-x snap-mandatory scrollbar-hide py-2 px-[5vw]">
                        {galleryImages.map((img, index) => (
                            <button class={`gallery-thumb mobile-thumb group flex-none w-[28vw] md:w-[22vw] aspect-square bg-zinc-50 border border-zinc-200 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none ring-0 snap-center ${index === 0 ? 'active' : ''}`} data-index={index} data-src={img.src.src} aria-label={`View ${img.label}`}>
                                <Image src={img.src} width={300} alt={`Thumbnail ${index + 1}`} class="w-full h-full object-cover pointer-events-none" />
                            </button>
                        ))}
                    </div>
                </div>

                <!-- Desktop Grid -->
                <div class="hidden xl:grid xl:col-span-5 w-full grid-cols-4 grid-rows-4 gap-3 content-start">
                    {galleryImages.map((img, index) => (
                        <button class={`gallery-thumb desktop-thumb group w-full h-full aspect-auto bg-zinc-50 border border-zinc-200 rounded-xl overflow-hidden relative cursor-pointer focus:outline-none ring-0 ${index === 0 ? 'active' : ''}`} data-index={index} data-src={img.src.src} aria-label={`View ${img.label}`}>
                            <Image src={img.src} width={300} alt={`Thumbnail ${index + 1}`} class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110 pointer-events-none" />
                        </button>
                    ))}
                </div>

            </div>
        </section>

        <!-- ========================================== -->
        <!-- LOCATION & AREA                            -->
        <!-- ========================================== -->
        <section id="area" class="px-6 py-24 md:py-32 lg:py-48 max-w-4xl mx-auto border-t border-zinc-200">
            <div class="reveal-el text-center mb-12 md:mb-16 lg:mb-24">
                <span class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400 mb-6 block">The Area</span>
                <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-light text-zinc-800 tracking-wide">Minamigaoka, Karuizawa</h2>
            </div>

            <div class="flex flex-col border-t border-zinc-200">
                
                <div class="reveal-el flex flex-col md:flex-row py-6 md:py-8 border-b border-zinc-200 gap-2 md:gap-8">
                    <div class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400 md:w-1/3 pt-1">Address</div>
                    <div class="flex flex-col gap-6 md:w-2/3">
                        <div class="font-sans text-sm md:text-base lg:text-lg text-zinc-800 font-light leading-loose flex flex-col gap-1">
                            <span>19-29 Seisatsuba, Oaza Nagakura, Karuizawa-machi, Nagano</span>
                            <span class="text-xs md:text-sm text-zinc-500 font-light tracking-wide mt-1">長野県北佐久郡軽井沢町大字長倉字制札場１９－２９</span>
                        </div>
                        
                        <a href="https://maps.app.goo.gl/4fDoEjxtN8prwHbq5" target="_blank" rel="noopener noreferrer" class="group block w-full h-48 md:h-64 bg-zinc-200 rounded-lg overflow-hidden relative border border-zinc-200 mt-2 focus:outline-none focus:ring-2 focus:ring-zinc-800 focus:ring-offset-4 transition-all">
                            <iframe 
                                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d25667.65363024847!2d138.583163704386!3d36.34118042571216!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x601dd22f281e8eb7%3A0xc6de9e01db109bb2!2sNagakura%2C%20Karuizawa%2C%20Kitasaku%20District%2C%20Nagano%20389-0111%2C%20Japan!5e0!3m2!1sen!2sus!4v1700000000000!5m2!1sen!2sus" 
                                width="100%" 
                                height="100%" 
                                style="border:0;" 
                                allowfullscreen="" 
                                loading="lazy" 
                                referrerpolicy="no-referrer-when-downgrade"
                                class="absolute inset-0 pointer-events-none grayscale contrast-[1.1] opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700 ease-in-out"
                                tabindex="-1"
                                aria-hidden="true"
                            ></iframe>
                            
                            <div class="absolute inset-0 bg-zinc-900/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center pointer-events-none">
                                <span class="bg-white/95 backdrop-blur-sm text-zinc-800 font-sans text-[10px] md:text-xs font-medium tracking-widest uppercase px-6 py-3 rounded-full border border-zinc-200/50 transform translate-y-2 group-hover:translate-y-0 transition-transform duration-500 ease-out">
                                    Open in Maps →
                                </span>
                            </div>
                        </a>
                    </div>
                </div>

                <div class="reveal-el flex flex-col md:flex-row py-6 md:py-8 border-b border-zinc-200 gap-2 md:gap-8">
                    <div class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400 md:w-1/3 pt-1">The Estate</div>
                    <div class="font-sans text-sm md:text-base lg:text-lg text-zinc-800 font-light md:w-2/3 leading-loose">
                        A magnificent luxury compound sitting on a sprawling 2,981.31 ㎡ (approx. 900 Tsubo) private forest plot.
                    </div>
                </div>

                <div class="reveal-el flex flex-col md:flex-row py-6 md:py-8 border-b border-zinc-200 gap-2 md:gap-8">
                    <div class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400 md:w-1/3 pt-1">Neighborhood</div>
                    <div class="font-sans text-sm md:text-base lg:text-lg text-zinc-800 font-light md:w-2/3 leading-loose">
                        Located within the prestigious Minamigaoka Project area. This enclave offers profound tranquility and seclusion, sitting immediately adjacent to the lush greens of the Karuizawa Golf Club.
                    </div>
                </div>
                
                <div class="reveal-el flex flex-col md:flex-row py-6 md:py-8 border-b border-zinc-200 gap-2 md:gap-8">
                    <div class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400 md:w-1/3 pt-1">Access</div>
                    <div class="font-sans text-sm md:text-base lg:text-lg text-zinc-800 font-light md:w-2/3 leading-loose">
                        Conveniently accessed via the National Route 18 Bypass, offering a seamless journey from the Hokuriku Shinkansen and central Tokyo.
                    </div>
                </div>

            </div>
        </section>

        <!-- ========================================== -->
        <!-- CONTACT & INQUIRY                          -->
        <!-- ========================================== -->
        <section id="inquire" class="px-6 py-24 md:py-32 lg:py-48 max-w-3xl mx-auto border-t border-zinc-200">
            <div class="reveal-el text-center mb-12 md:mb-16 lg:mb-24">
                <span class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400 mb-6 block">Private Viewing</span>
                <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-light text-zinc-800 tracking-wide mb-8">Inquire about this property</h2>
            </div>

            <form class="flex flex-col gap-8 md:gap-12">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
                    <div class="reveal-el flex flex-col gap-2 md:gap-3">
                        <label for="name" class="font-sans text-[10px] md:text-xs font-medium tracking-widest uppercase text-zinc-400">Name</label>
                        <input type="text" id="name" class="w-full bg-transparent border-b border-zinc-300 py-2 font-sans text-base md:text-lg font-light focus:outline-none focus:border-zinc-800 transition-colors rounded-none" required />
                    </div>
                    <div class="reveal-el flex flex-col gap-2 md:gap-3">
                        <label for="email" class="font-sans text-[10px] md:text-xs font-medium tracking-widest uppercase text-zinc-400">Email</label>
                        <input type="email" id="email" class="w-full bg-transparent border-b border-zinc-300 py-2 font-sans text-base md:text-lg font-light focus:outline-none focus:border-zinc-800 transition-colors rounded-none" required />
                    </div>
                </div>
                <div class="reveal-el flex flex-col gap-2 md:gap-3">
                    <label for="message" class="font-sans text-[10px] md:text-xs font-medium tracking-widest uppercase text-zinc-400">Message</label>
                    <textarea id="message" rows="4" class="w-full bg-transparent border-b border-zinc-300 py-2 font-sans text-base md:text-lg font-light focus:outline-none focus:border-zinc-800 transition-colors resize-none rounded-none"></textarea>
                </div>
                <button type="submit" class="reveal-el self-center mt-4 md:mt-8 bg-zinc-800 text-white font-sans text-[10px] md:text-xs font-medium tracking-widest uppercase px-10 md:px-12 py-4 md:py-5 hover:bg-zinc-700 transition-colors w-full md:w-auto cursor-pointer">
                    Submit Inquiry
                </button>
            </form>
        </section>

    </main>
    
    <div class="reveal-el">
        <Footer />
    </div>

    <!-- ========================================== -->
    <!-- LIGHTBOX OVERLAY                           -->
    <!-- ========================================== -->
    <div id="lightbox" class="fixed inset-0 z-50 flex items-center justify-center bg-zinc-950/95 opacity-0 pointer-events-none transition-opacity duration-500 cursor-none touch-none">
        
        <button id="lightbox-close" class="absolute top-6 right-6 md:top-12 md:right-12 text-white font-sans text-[10px] md:text-xs font-medium tracking-widest uppercase p-4 hover:text-zinc-400 transition-colors cursor-pointer z-50">
            Close ×
        </button>

        <div class="relative w-full h-full max-w-7xl max-h-[85vh] p-6 md:p-12 lg:p-24 flex items-center justify-center overflow-hidden pb-32 md:pb-32">
            <img id="lightbox-image" src="" alt="HD Floorplan" class="max-w-full max-h-full object-contain opacity-0 transition-opacity duration-300 select-none cursor-none touch-none" draggable="false" />
        </div>
        
        <div class="absolute bottom-8 md:bottom-12 left-0 w-full px-6 md:px-12 flex items-center justify-between z-50 pointer-events-none">
            <button id="lightbox-prev" class="pointer-events-auto text-white font-sans text-[10px] md:text-xs font-medium tracking-widest uppercase py-4 pr-4 hover:text-zinc-400 transition-colors cursor-pointer">
                ← Prev
            </button>
            <button id="lightbox-next" class="pointer-events-auto text-white font-sans text-[10px] md:text-xs font-medium tracking-widest uppercase py-4 pl-4 hover:text-zinc-400 transition-colors cursor-pointer">
                Next →
            </button>
        </div>

        <div class="absolute bottom-20 md:bottom-12 left-1/2 -translate-x-1/2 z-50 pointer-events-auto flex justify-center w-auto max-w-[85vw] md:max-w-[40vw]">
            <span id="lightbox-caption" class="inline-block bg-zinc-900/80 backdrop-blur-md text-white px-5 py-2.5 rounded-full font-sans text-[10px] md:text-xs font-medium tracking-widest uppercase border border-zinc-800/50 whitespace-nowrap overflow-hidden text-ellipsis"></span>
        </div>

    </div>

</Layout>

<!-- ========================================== -->
<!-- STYLES                                     -->
<!-- ========================================== -->
<style is:global>
    html, body {
        overflow-x: clip;
        width: 100%;
        /* Adjusted background color slightly to fit the zinc/neutral palette */
        background-color: #F4F4F5; 
    }
</style>

<style>
    @keyframes scrollDrop {
        0% { transform: translateY(-100%); opacity: 0; }
        50% { opacity: 1; }
        100% { transform: translateY(200%); opacity: 0; }
    }
    .animate-scroll-drop {
        animation: scrollDrop 2s cubic-bezier(0.77, 0, 0.175, 1) infinite;
    }

    .gallery-thumb::after {
        content: '';
        position: absolute;
        inset: 0;
        background-color: white;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }
    .gallery-thumb:hover::after {
        opacity: 0.15; 
    }
    .gallery-thumb.active::after {
        opacity: 0.65; 
    }
    .gallery-thumb.active {
        pointer-events: none; 
    }

    /* Edge blur for mobile carousel */
    .carousel-blur::before,
    .carousel-blur::after {
        content: '';
        position: absolute;
        top: -10px;
        bottom: -10px;
        width: 15vw; 
        max-width: 80px;
        pointer-events: none;
        z-index: 10;
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
    }
    .carousel-blur::before {
        left: -1px;
        background: linear-gradient(to right, rgba(244, 244, 245, 0.95) 0%, rgba(244, 244, 245, 0) 100%);
        -webkit-mask-image: linear-gradient(to right, black 0%, transparent 100%);
        mask-image: linear-gradient(to right, black 0%, transparent 100%);
    }
    .carousel-blur::after {
        right: -1px;
        background: linear-gradient(to left, rgba(244, 244, 245, 0.95) 0%, rgba(244, 244, 245, 0) 100%);
        -webkit-mask-image: linear-gradient(to left, black 0%, transparent 100%);
        mask-image: linear-gradient(to left, black 0%, transparent 100%);
    }

    /* Hide scrollbars for clean UI */
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
    .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>

<!-- ========================================== -->
<!-- SCRIPTS                                    -->
<!-- ========================================== -->
<script>
    document.addEventListener('DOMContentLoaded', () => {

        // ---------------------------------------------------------
        // 1. HIGH-PERFORMANCE SCROLL CROSSFADE ENGINE
        // ---------------------------------------------------------
        
        // Cache DOM elements up front so we don't query the DOM during scroll
        const crossfadeElements = Array.from(document.querySelectorAll('.scroll-crossfade')).map(container => ({
            container,
            target: container.querySelector('.crossfade-target') as HTMLElement
        })).filter(item => item.target !== null); // Ensure target exists

        if (crossfadeElements.length > 0) {
            let ticking = false;

            const updateCrossfades = () => {
                const wh = window.innerHeight;
                
                // Optimized loop
                for (let i = 0; i < crossfadeElements.length; i++) {
                    const { container, target } = crossfadeElements[i];
                    const rect = container.getBoundingClientRect();
                    
                    // Process only if visible
                    if (rect.top < wh && rect.bottom > 0) {
                        let progress = (wh - rect.top) / (wh + rect.height);
                        let opacity = (progress - 0.35) * (1 / 0.30);
                        
                        // Apply opacity with strict decimal limits for faster rendering
                        target.style.opacity = Math.max(0, Math.min(1, opacity)).toFixed(3);
                    }
                }
                ticking = false; 
            };
            
            // Bind to scroll event with a requestAnimationFrame lock
            window.addEventListener('scroll', () => {
                if (!ticking) {
                    window.requestAnimationFrame(updateCrossfades);
                    ticking = true;
                }
            }, { passive: true });
            
            updateCrossfades(); // Init on load
        }

        // ---------------------------------------------------------
        // 2. FLOORPLAN LIGHTBOX ENGINE
        // ---------------------------------------------------------
        const floorplanTriggers = document.querySelectorAll('.floorplan-trigger');
        const lightbox = document.getElementById('lightbox');
        const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement;
        const lightboxClose = document.getElementById('lightbox-close');
        const lightboxPrev = document.getElementById('lightbox-prev');
        const lightboxNext = document.getElementById('lightbox-next');
        const lightboxCaption = document.getElementById('lightbox-caption');

        if (lightbox && lightboxImage && floorplanTriggers.length > 0) {
            
            const floorplanData = Array.from(floorplanTriggers).map(t => ({
                src: t.getAttribute('data-hd-src'),
                caption: t.getAttribute('data-caption')
            }));

            let currentLbIndex = 0;
            let isLbTransitioning = false;
            let scale = 1, panX = 0, panY = 0, isPanning = false, startX = 0, startY = 0;
            let lastTapTime = 0, initialPinchDistance: number | null = null, initialScale = 1;

            const updateTransform = (smooth = false) => {
                lightboxImage.style.transition = smooth ? 'opacity 0.3s ease, transform 0.3s ease-out' : 'opacity 0.3s ease';
                lightboxImage.style.transform = `translate(${panX}px, ${panY}px) scale(${scale})`;
                lightboxImage.style.cursor = scale > 1 ? (isPanning ? 'grabbing' : 'grab') : 'default';
            };

            const getDistance = (touches: TouchList) => {
                return Math.hypot(
                    touches[0].clientX - touches[1].clientX,
                    touches[0].clientY - touches[1].clientY
                );
            };

            lightbox.addEventListener('wheel', (e) => {
                if (!lightbox.classList.contains('opacity-100')) return;
                e.preventDefault(); 
                
                scale += e.deltaY < 0 ? 0.15 : -0.15;
                scale = Math.max(1, Math.min(scale, 4));
                if (scale === 1) { panX = 0; panY = 0; }
                
                updateTransform();
            }, { passive: false });

            lightboxImage.addEventListener('dblclick', (e) => {
                e.preventDefault();
                if (scale > 1) { scale = 1; panX = 0; panY = 0; } 
                else { scale = 2.5; }
                updateTransform(true);
            });

            lightboxImage.addEventListener('mousedown', (e) => {
                if (scale === 1) return;
                e.preventDefault(); 
                isPanning = true;
                startX = e.clientX - panX;
                startY = e.clientY - panY;
                updateTransform();
            });

            window.addEventListener('mousemove', (e) => {
                if (!isPanning) return;
                panX = e.clientX - startX;
                panY = e.clientY - startY;
                updateTransform();
            });

            window.addEventListener('mouseup', () => { isPanning = false; updateTransform(); });
            window.addEventListener('mouseleave', () => { isPanning = false; updateTransform(); });

            lightboxImage.addEventListener('touchstart', (e) => {
                if (e.touches.length === 1) {
                    const currentTime = new Date().getTime();
                    const tapLength = currentTime - lastTapTime;

                    if (tapLength < 300 && tapLength > 0) {
                        e.preventDefault(); 
                        if (scale > 1) { scale = 1; panX = 0; panY = 0; } 
                        else { scale = 2.5; }
                        updateTransform(true);
                    } else {
                        if (scale > 1) {
                            isPanning = true;
                            startX = e.touches[0].clientX - panX;
                            startY = e.touches[0].clientY - panY;
                        }
                    }
                    lastTapTime = currentTime;
                } else if (e.touches.length === 2) {
                    e.preventDefault();
                    isPanning = false;
                    initialPinchDistance = getDistance(e.touches);
                    initialScale = scale;
                }
            }, { passive: false });

            lightboxImage.addEventListener('touchmove', (e) => {
                if (e.touches.length === 1 && isPanning) {
                    e.preventDefault();
                    panX = e.touches[0].clientX - startX;
                    panY = e.touches[0].clientY - startY;
                    updateTransform();
                } else if (e.touches.length === 2 && initialPinchDistance) {
                    e.preventDefault();
                    const currentDistance = getDistance(e.touches);
                    const pinchRatio = currentDistance / initialPinchDistance;
                    scale = Math.max(1, Math.min(initialScale * pinchRatio, 4));
                    if (scale === 1) { panX = 0; panY = 0; }
                    updateTransform();
                }
            }, { passive: false });

            lightboxImage.addEventListener('touchend', () => {
                isPanning = false;
                initialPinchDistance = null;
            });

            function updateLightbox(index: number) {
                if (isLbTransitioning) return;
                isLbTransitioning = true;
                currentLbIndex = index;
                
                lightboxImage.classList.remove('opacity-100');
                lightboxImage.classList.add('opacity-0');
                
                setTimeout(() => {
                    scale = 1; panX = 0; panY = 0; updateTransform(true); 
                    if (floorplanData[currentLbIndex].src) {
                        lightboxImage.src = floorplanData[currentLbIndex].src!;
                    }
                    if (lightboxCaption) {
                        lightboxCaption.textContent = floorplanData[currentLbIndex].caption;
                    }
                }, 300); 
            }

            lightboxImage.onload = () => {
                if (lightbox.classList.contains('opacity-100')) {
                    lightboxImage.classList.remove('opacity-0');
                    lightboxImage.classList.add('opacity-100');
                    isLbTransitioning = false;
                }
            };

            floorplanTriggers.forEach((trigger, index) => {
                trigger.addEventListener('click', (e) => {
                    e.preventDefault();
                    currentLbIndex = index;
                    
                    scale = 1; panX = 0; panY = 0; updateTransform(true);
                    
                    const hdSrc = floorplanData[currentLbIndex].src;
                    if (hdSrc) lightboxImage.src = hdSrc;
                    
                    if (lightboxCaption) {
                        lightboxCaption.textContent = floorplanData[currentLbIndex].caption;
                    }
                    
                    lightbox.classList.remove('pointer-events-none', 'opacity-0');
                    lightbox.classList.add('opacity-100');

                    document.body.style.overflow = 'hidden';
                    if (window['lenis']) window['lenis'].stop();
                });
            });

            if (lightboxPrev && lightboxNext) {
                lightboxPrev.addEventListener('click', (e) => {
                    e.stopPropagation();
                    updateLightbox((currentLbIndex - 1 + floorplanData.length) % floorplanData.length);
                });

                lightboxNext.addEventListener('click', (e) => {
                    e.stopPropagation();
                    updateLightbox((currentLbIndex + 1) % floorplanData.length);
                });
            }

            const closeLightbox = () => {
                lightbox.classList.remove('opacity-100');
                lightbox.classList.add('opacity-0', 'pointer-events-none');
                lightboxImage.classList.remove('opacity-100');
                lightboxImage.classList.add('opacity-0');
                
                setTimeout(() => { 
                    lightboxImage.src = ''; 
                    scale = 1; panX = 0; panY = 0; updateTransform(true);
                    
                    document.body.style.overflow = '';
                    if (window['lenis']) window['lenis'].start();
                }, 300);
            };

            if (lightboxClose) lightboxClose.addEventListener('click', closeLightbox);
            
            lightbox.addEventListener('click', (e) => {
                if (e.target === lightbox && scale === 1) closeLightbox();
            });
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && lightbox.classList.contains('opacity-100')) closeLightbox();
            });
        }

        // ---------------------------------------------------------
        // 3. MAIN GALLERY INTERACTIVE ENGINE
        // ---------------------------------------------------------
        const mainImage = document.getElementById('main-gallery-image') as HTMLImageElement;
        const mainContainer = document.getElementById('main-gallery-container');
        const thumbnails = document.querySelectorAll('.gallery-thumb');
        const mobileScroll = document.getElementById('mobile-thumb-scroll');
        const swipeIndicator = document.getElementById('swipe-indicator');

        if (!mainImage || !mainContainer || thumbnails.length === 0) return;

        let isTransitioning = false;
        let currentIndex = 0;

        const desktopThumbs = document.querySelectorAll('.desktop-thumb');
        const imageList = Array.from(desktopThumbs).map(t => t.getAttribute('data-src'));

        // Preload images silently in background
        window.addEventListener('load', () => {
            setTimeout(() => {
                imageList.forEach(src => {
                    if (src) {
                        const img = new Image();
                        img.src = src;
                    }
                });
            }, 800);
        });

        let activeMobileThumb: Element | null = document.querySelector('.mobile-thumb[data-index="0"]');

        function updateGallery(clickedThumbElement: Element) {
            if (!clickedThumbElement || isTransitioning || clickedThumbElement.classList.contains('active')) return;
            
            isTransitioning = true;
            
            if (swipeIndicator && !swipeIndicator.classList.contains('opacity-0')) {
                swipeIndicator.classList.add('opacity-0');
            }

            const newSrc = clickedThumbElement.getAttribute('data-src');
            const realIndex = parseInt(clickedThumbElement.getAttribute('data-index') || "0", 10);

            mainImage.style.opacity = '0';

            setTimeout(() => {
                if (newSrc) mainImage.src = newSrc;
                currentIndex = realIndex;

                thumbnails.forEach(t => t.classList.remove('active'));
                const matchingThumbs = document.querySelectorAll(`.gallery-thumb[data-index="${realIndex}"]`);
                matchingThumbs.forEach(t => t.classList.add('active'));

                if (window.innerWidth < 1280 && mobileScroll && activeMobileThumb) {
                    activeMobileThumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
                }

                mainImage.onload = () => {
                    mainImage.style.opacity = '1';
                    isTransitioning = false; 
                };

                if(mainImage.complete) {
                     mainImage.style.opacity = '1';
                     isTransitioning = false; 
                }

            }, 300); 
        }

        thumbnails.forEach(thumb => {
            thumb.addEventListener('click', () => {
                if (thumb.classList.contains('mobile-thumb')) {
                    activeMobileThumb = thumb; 
                } else {
                    const realIndex = thumb.getAttribute('data-index');
                    activeMobileThumb = document.querySelector(`.mobile-thumb[data-index="${realIndex}"]`);
                }
                updateGallery(thumb);
            });
        });

        let touchStartX = 0;
        let touchEndX = 0;

        mainContainer.addEventListener('touchstart', (e: TouchEvent) => {
            touchStartX = e.changedTouches[0].screenX;
        }, { passive: true });

        mainContainer.addEventListener('touchend', (e: TouchEvent) => {
            touchEndX = e.changedTouches[0].screenX;
            handleSwipe();
        }, { passive: true });

        function handleSwipe() {
            if (window.innerWidth >= 1280 || !activeMobileThumb) return; 
            
            const threshold = 40; 
            const allMobileThumbs = Array.from(document.querySelectorAll('.mobile-thumb'));
            const currentIndexInArray = allMobileThumbs.indexOf(activeMobileThumb as Element);
            
            if (touchStartX - touchEndX > threshold) {
                const nextIndex = (currentIndexInArray + 1) % allMobileThumbs.length;
                activeMobileThumb = allMobileThumbs[nextIndex];
                updateGallery(activeMobileThumb);
            } else if (touchEndX - touchStartX > threshold) {
                const prevIndex = (currentIndexInArray - 1 + allMobileThumbs.length) % allMobileThumbs.length;
                activeMobileThumb = allMobileThumbs[prevIndex];
                updateGallery(activeMobileThumb);
            }
        }
    });
</script>