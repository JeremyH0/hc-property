---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Carousel3D from '../components/Carousel3D.astro';
import { Image } from 'astro:assets';

// ==========================================
// IMAGE IMPORTS
// ==========================================
// Hero
import imgHeroHQ from '../assets/gallery/hero-hq.jpg';

// Concept Section (Crossfades)
import imgDrawing from '../assets/gallery/drawing.jpeg';

// ==========================================
// NEW IMPORTS FOR BLOCK 1
// ==========================================
import img1_7 from '../assets/gallery/1.7.jpeg';
import img1_4 from '../assets/gallery/1.4.jpeg';
import img1_2 from '../assets/gallery/1.2.jpeg';

// ==========================================
// Indoor Living Carousel Images Block 2
// ==========================================
import img2_1 from '../assets/gallery/2.1.jpeg';
import img2_4 from '../assets/gallery/2.4.jpeg';
import img2_16 from '../assets/gallery/2.16.jpeg';
import img2_15 from '../assets/gallery/2.15.jpeg';

// ==========================================
// ACCOMMODATIONS IMPORTS (Block 3)
// ==========================================
import img3_18 from '../assets/gallery/3.18.jpeg';
import img3_10 from '../assets/gallery/3.10.jpeg';
import img3_15 from '../assets/gallery/3.15.jpeg';
import img3_5 from '../assets/gallery/3.5.jpeg';

// ==========================================
// WELLNESS IMPORTS (Block 4)
// ==========================================
import img4_1 from '../assets/gallery/4.1.jpeg';
import img4_2 from '../assets/gallery/4.2.jpeg';
import img4_3 from '../assets/gallery/4.3.jpeg';
import img4_4 from '../assets/gallery/4.4.jpeg';

// ==========================================
// GROUNDS & FIREPIT IMPORTS (Block 5)
// ==========================================
import img5_20 from '../assets/gallery/5.20.jpeg';
import img5_16 from '../assets/gallery/5.16.jpeg';
import img5_17 from '../assets/gallery/5.17.jpeg';
import img5_13 from '../assets/gallery/5.13.jpeg';

// Floorplans
import imgFloorplan1 from '../assets/gallery/floorplan1.jpeg';
import imgFloorplan2 from '../assets/gallery/floorplan2.jpeg';
import imgFloorplan1HD from '../assets/gallery/floorplan1hd.jpeg';
import imgFloorplan2HD from '../assets/gallery/floorplan2hd.jpeg';

// ==========================================
// 16-Image Gallery
// ==========================================
import img0_1 from '../assets/gallery/0.1.jpeg';
import img0_2 from '../assets/gallery/0.2.jpeg';
import img0_3 from '../assets/gallery/0.3.jpeg';
import img0_4 from '../assets/gallery/0.4.jpeg';
import img0_5 from '../assets/gallery/0.5.jpeg';
import img0_6 from '../assets/gallery/0.6.jpeg';
import img0_7 from '../assets/gallery/0.7.jpeg';
import img0_8 from '../assets/gallery/0.8.jpeg';
import img0_9 from '../assets/gallery/0.9.jpeg';
import img0_10 from '../assets/gallery/0.10.jpeg';
import img0_11 from '../assets/gallery/0.11.jpeg';
import img0_12 from '../assets/gallery/0.12.jpeg';
import img0_13 from '../assets/gallery/0.13.jpeg';
import img0_14 from '../assets/gallery/0.14.jpeg';
import img0_15 from '../assets/gallery/0.15.jpeg';
import img0_16 from '../assets/gallery/0.16.jpeg';

// Array for mapping the gallery grid/carousel
const galleryImages = [
    { src: img0_1, label: "Image 1" }, { src: img0_2, label: "Image 2" },
    { src: img0_3, label: "Image 3" }, { src: img0_4, label: "Image 4" },
    { src: img0_5, label: "Image 5" }, { src: img0_6, label: "Image 6" },
    { src: img0_7, label: "Image 7" }, { src: img0_8, label: "Image 8" },
    { src: img0_9, label: "Image 9" }, { src: img0_10, label: "Image 10" },
    { src: img0_11, label: "Image 11" }, { src: img0_12, label: "Image 12" },
    { src: img0_13, label: "Image 13" }, { src: img0_14, label: "Image 14" },
    { src: img0_15, label: "Image 15" }, { src: img0_16, label: "Image 16" }
];
---
<Layout title="Karuizawa | Hirafu Capital GK">
    <Navigation />
    
    <main class="w-full tracking-normal leading-loose">
        
        <!-- ========================================== -->
        <!-- HERO SECTION                               -->
        <!-- ========================================== -->
        <section id="hero-section" class="relative w-full h-[35svh] min-h-[320px] md:h-[35svh] md:min-h-[400px] lg:h-[100svh] lg:min-h-[700px] flex flex-col overflow-hidden bg-zinc-950">
            
            <div class="absolute inset-0 w-full h-full">
                <Image 
                    src={imgHeroHQ} 
                    alt="Exterior view of the Karuizawa estate at dusk, showcasing the main residence and guest house surrounded by forest." 
                    widths={[768, 1280, 1920, 2560]}
                    sizes="100vw"
                    class="w-full h-full object-cover opacity-90" 
                    loading="eager" 
                    fetchpriority="high" 
                />
                <!-- Avoided pure black: using zinc-950 and zinc-900 -->
                <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/80 md:from-zinc-950/60 lg:from-zinc-950/50 via-transparent to-zinc-900/40"></div>
            </div>

            <div class="relative z-10 flex flex-col items-start justify-end text-left px-6 md:px-12 w-full max-w-[100rem] mx-auto h-full pb-8 md:pb-12 lg:pb-32">
                <h1 class="hero-reveal font-sans text-2xl md:text-3xl lg:text-5xl font-light tracking-[0.15em] text-white drop-shadow-sm flex items-center">
                    Karuizawa<span class="mx-3 md:mx-4 font-extralight text-white text-xl md:text-2xl lg:text-4xl">|</span><span class="tracking-[0.1em]">軽井沢</span> 
                </h1>
            </div>

            <div class="hidden xl:flex absolute bottom-12 right-12 z-10 hero-reveal flex-col items-center gap-4">
                <span class="font-sans text-[9px] tracking-[0.3em] uppercase text-white" style="writing-mode: vertical-rl;">Scroll</span>
                <div class="w-px h-12 bg-white/20 relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-1/2 bg-white animate-scroll-drop"></div>
                </div>
            </div>
        </section>

        <!-- ========================================== -->
        <!-- CONCEPT SECTION                            -->
        <!-- ========================================== -->
        <section id="concept" class="px-6 py-24 md:py-32 lg:py-40 max-w-4xl mx-auto text-center">
            <span class="reveal-el font-sans text-xs font-medium tracking-widest uppercase text-zinc-400 mb-8 block">The Estate</span>
            <h2 class="reveal-el font-serif text-3xl md:text-5xl lg:text-6xl font-light text-zinc-800 tracking-wide mb-12 md:mb-16 leading-tight">
                A sanctuary divided, <br class="hidden md:block"/> yet perfectly unified.
            </h2>
            <div class="reveal-el font-sans text-zinc-500 font-light leading-loose flex flex-col gap-6 md:gap-8 text-left md:text-center text-sm md:text-base lg:text-lg max-w-3xl mx-auto">
                <p>Set within a deeply forested enclave of Karuizawa, this remarkable residence is ingeniously designed as two distinct structures. A main house and a guest house connected seamlessly by an elegant hallway.</p>
                <p>This intelligent layout allows the property to function flawlessly as a single, grand estate for large gatherings, or it can be secured to provide absolute privacy and independence for both hosts and guests.</p>
            </div>
        </section>

        <!-- ========================================== -->
        <!-- LIFESTYLE & AMENITIES                      -->
        <!-- ========================================== -->
        <section id="architecture" class="flex flex-col w-full">
            
            <!-- 1. Scale & Motor Court -->
            <div class="w-full py-16 md:py-24 lg:py-32">
                <div class="px-6 md:px-12 max-w-[100rem] mx-auto grid grid-cols-1 xl:grid-cols-2 gap-12 xl:gap-24 items-center">
                    <div class="reveal-el flex flex-col gap-4 md:gap-6 xl:px-8 order-2 xl:order-1">
                        <span class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400">The Arrival</span>
                        <h3 class="font-serif text-2xl md:text-3xl lg:text-4xl font-light text-zinc-800">Where the Journey Begins</h3>
                        <p class="font-sans text-sm md:text-base text-zinc-500 font-light leading-loose">The experience begins as private gates open to a hidden forest sanctuary. The estate's sheer magnitude immediately unfolds, designed to welcome family and friends with effortless grace. A thoughtfully integrated motor court provides ample parking for five cars, seamlessly blending everyday convenience with profound seclusion.</p>
                    </div>
                    <div class="reveal-el w-full order-1 xl:order-2">
                        <Carousel3D images={[img1_7, img1_4, img1_2]} />
                    </div>
                </div>
            </div>
            
            <!-- Subtle Mobile Separator -->
            <div class="xl:hidden w-full max-w-md mx-auto h-px bg-gradient-to-r from-transparent via-zinc-200 to-transparent opacity-70"></div>

            <!-- 2. Indoor Living -->
            <div class="w-full py-16 md:py-24 lg:py-32">
                <div class="px-6 md:px-12 max-w-[100rem] mx-auto grid grid-cols-1 xl:grid-cols-2 gap-12 xl:gap-24 items-center">
                    <div class="reveal-el w-full order-1 xl:order-1">
                        <Carousel3D images={[img2_1, img2_4, img2_16, img2_15]} />
                    </div>
                    <div class="reveal-el flex flex-col gap-4 md:gap-6 xl:px-8 order-2 xl:order-2">
                        <span class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400">Indoor Living</span>
                        <h3 class="font-serif text-2xl md:text-3xl lg:text-4xl font-light text-zinc-800">Dual Living Spaces</h3>
                        <p class="font-sans text-sm md:text-base text-zinc-500 font-light leading-loose">Reflecting the estate's dual-wing design, both the main and guest houses feature their own expansive living rooms and premium, fully equipped kitchens. These central spaces offer a masterful blend of striking architecture and lived-in warmth, where expansive windows draw the tranquil forest inward. Whether hosting a grand gathering in the main residence or enjoying a quiet morning coffee in the guest house, the interiors invite effortless connection and absolute comfort.</p>
                    </div>
                </div>
            </div>

            <!-- Subtle Mobile Separator -->
            <div class="xl:hidden w-full max-w-md mx-auto h-px bg-gradient-to-r from-transparent via-zinc-200 to-transparent opacity-70"></div>

            <!-- 3. Accommodations -->
            <div class="w-full py-16 md:py-24 lg:py-32">
                <div class="px-6 md:px-12 max-w-[100rem] mx-auto grid grid-cols-1 xl:grid-cols-2 gap-12 xl:gap-24 items-center">
                    <div class="reveal-el flex flex-col gap-4 md:gap-6 xl:px-8 order-2 xl:order-1">
                        <span class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400">Accommodations</span>
                        <h3 class="font-serif text-2xl md:text-3xl lg:text-4xl font-light text-zinc-800">Seven Private Suites</h3>
                        <p class="font-sans text-sm md:text-base text-zinc-500 font-light leading-loose">When evening falls, the estate offers restful comfort across seven beautifully appointed ensuite bedrooms. The intelligent layout features four sanctuary suites in the main residence and three in the guest house, allowing for seamless shared living or absolute, independent privacy. Each room is designed as a tranquil retreat with soft, tactile finishes to help you recharge.</p>
                    </div>
                    <div class="reveal-el w-full order-1 xl:order-2">
                        <Carousel3D images={[img3_18, img3_10, img3_15, img3_5]} />
                    </div>
                </div>
            </div>

            <!-- Subtle Mobile Separator -->
            <div class="xl:hidden w-full max-w-md mx-auto h-px bg-gradient-to-r from-transparent via-zinc-200 to-transparent opacity-70"></div>

            <!-- 4. Wellness Retreat (Spa) -->
            <div class="w-full py-16 md:py-24 lg:py-32">
                <div class="px-6 md:px-12 max-w-[100rem] mx-auto grid grid-cols-1 xl:grid-cols-2 gap-12 xl:gap-24 items-center">
                    <div class="reveal-el w-full order-1 xl:order-1">
                        <Carousel3D images={[img4_1, img4_2, img4_3, img4_4]} />
                    </div>
                    <div class="reveal-el flex flex-col gap-4 md:gap-6 xl:px-8 order-2 xl:order-2">
                        <span class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400">Wellness</span>
                        <h3 class="font-serif text-2xl md:text-3xl lg:text-4xl font-light text-zinc-800">The Private Spa & Sauna</h3>
                        <p class="font-sans text-sm md:text-base text-zinc-500 font-light leading-loose">Discover a resort-grade wellness experience in the absolute privacy of your own home. The dedicated indoor spa features large dual soaking tubs and a custom-crafted cedar sauna. Bathed in natural forest light, it provides a deeply restorative escape day or night.</p>
                    </div>
                </div>
            </div>

            <!-- Subtle Mobile Separator -->
            <div class="xl:hidden w-full max-w-md mx-auto h-px bg-gradient-to-r from-transparent via-zinc-200 to-transparent opacity-70"></div>

            <!-- 5. Landscape & Firepit -->
            <div class="w-full py-16 md:py-24 lg:py-32">
                <div class="px-6 md:px-12 max-w-[100rem] mx-auto grid grid-cols-1 xl:grid-cols-2 gap-12 xl:gap-24 items-center">
                    <div class="reveal-el flex flex-col gap-4 md:gap-6 xl:px-8 order-2 xl:order-1">
                        <span class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400">The Grounds</span>
                        <h3 class="font-serif text-2xl md:text-3xl lg:text-4xl font-light text-zinc-800">The Sunken Forest Firepit</h3>
                        <p class="font-sans text-sm md:text-base text-zinc-500 font-light leading-loose">As twilight descends, the grounds reveal their most enchanting space. An expansive wooden deck gives way to a sunken stone firepit, anchoring the sprawling private plot. Gather around the warmth of the fire on crisp, star-filled evenings a deeply immersive experience where the rustle of ancient trees is your only soundtrack.</p>
                    </div>
                    <div class="reveal-el w-full order-1 xl:order-2">
                        <Carousel3D images={[img5_20, img5_16, img5_17, img5_13]} />
                    </div>
                </div>
            </div>
        </section>

        <!-- ========================================== -->
        <!-- FLOORPLAN SECTION                          -->
        <!-- ========================================== -->
        <section id="floorplan" class="px-6 md:px-12 py-24 md:py-32 lg:py-48 max-w-[100rem] mx-auto border-t border-zinc-200">
            <div class="grid grid-cols-1 xl:grid-cols-12 gap-12 xl:gap-24 relative items-start">
                
                <div class="xl:col-span-4 xl:sticky xl:top-32 transition-all duration-300">
                    <div class="reveal-el flex flex-col gap-6 md:gap-8">
                        <div>
                            <span class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400 mb-4 block">The Masterplan</span>
                            <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-light text-zinc-800 tracking-wide">Structural Harmony.</h2>
                        </div>
                        <div class="flex flex-col gap-4 md:gap-6 font-sans text-sm md:text-base text-zinc-500 font-light leading-loose">
                            <p>The first floor establishes the estate's dual-wing concept. A central gallery bridges the main residence and the guest house, wrapping around a landscaped garden and expansive outdoor terrace.</p>
                            <p>The second floor is dedicated entirely to privacy and wellness. It houses the seven ensuite bedrooms, alongside the main house's dedicated spa and sauna retreat.</p>
                        </div>
                    </div>
                </div>

                <div class="xl:col-span-8 flex flex-col gap-12 md:gap-16 lg:gap-24">
                    
                    <div class="reveal-el flex flex-col gap-6">
                        <button class="floorplan-trigger group w-full bg-zinc-50 p-4 md:p-8 lg:p-12 rounded-xl flex items-center justify-center border border-zinc-200 relative overflow-hidden cursor-pointer" data-index="0" data-hd-src={imgFloorplan1HD.src} data-caption="First Floor: Living & Gathering Spaces">
                            <Image src={imgFloorplan1} alt="First Floor Plan" class="w-full h-auto object-contain mix-blend-multiply opacity-80 transition-transform duration-700 ease-out group-hover:scale-105" />
                            
                            <div class="absolute inset-0 bg-white/10 backdrop-blur-[1px] opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center pointer-events-none">
                                <span class="font-sans text-[10px] md:text-xs font-medium tracking-widest uppercase text-zinc-800 border border-zinc-800 px-6 py-3 rounded-full bg-white/90">View Floorplan</span>
                            </div>
                        </button>
                        <span class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400 text-center xl:text-left">
                            First Floor: Living & Gathering Spaces
                        </span>
                    </div>
                    
                    <div class="reveal-el flex flex-col gap-6">
                        <button class="floorplan-trigger group w-full bg-zinc-50 p-4 md:p-8 lg:p-12 rounded-xl flex items-center justify-center border border-zinc-200 relative overflow-hidden cursor-pointer" data-index="1" data-hd-src={imgFloorplan2HD.src} data-caption="Second Floor: Private Suites & Spa">
                            <Image src={imgFloorplan2} alt="Second Floor Plan" class="w-full h-auto object-contain mix-blend-multiply opacity-80 transition-transform duration-700 ease-out group-hover:scale-105" />
                            
                            <div class="absolute inset-0 bg-white/10 backdrop-blur-[1px] opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center pointer-events-none">
                                <span class="font-sans text-[10px] md:text-xs font-medium tracking-widest uppercase text-zinc-800 border border-zinc-800 px-6 py-3 rounded-full bg-white/90">View Floorplan</span>
                            </div>
                        </button>
                        <span class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400 text-center xl:text-left">
                            Second Floor: Private Suites & Spa
                        </span>
                    </div>

                    <div class="reveal-el">
                        <p class="font-sans text-xs text-zinc-400 font-light italic leading-loose text-center xl:text-left">
                            * For indicative purposes only.
                        </p>
                    </div>

                </div>
            </div>
        </section>

        <!-- ========================================== -->
        <!-- ARCHITECT & DESIGN                         -->
        <!-- ========================================== -->
        <section id="sasazawa" class="px-6 py-24 md:py-32 lg:py-40 max-w-[100rem] mx-auto border-t border-zinc-200 overflow-hidden">
            <div class="reveal-el max-w-6xl mx-auto w-full flex flex-col gap-12 md:gap-16">
                
                <!-- Borderless Architectural Drawing (Top) -->
                <div class="w-full overflow-hidden">
                    <Image 
                        src={imgDrawing} 
                        alt="Architectural drawing of the Sasazawa design" 
                        class="w-full h-auto object-cover scale-[1.01]"
                    />
                </div>

                <!-- Text Grid (Bottom) -->
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start mt-4 md:mt-8">
                    
                    <!-- Title Area -->
                    <div class="lg:col-span-4 flex flex-col items-start gap-3">
                        <span class="font-sans text-[10px] md:text-xs font-semibold tracking-widest uppercase text-zinc-400">Architecture & Construction</span>
                        <h3 class="font-serif text-3xl md:text-4xl lg:text-5xl font-light text-zinc-800">Sasazawa</h3>
                    </div>
                    
                    <!-- Subtle Vertical Separator (Desktop only) -->
                    <div class="hidden lg:flex lg:col-span-1 justify-center h-full">
                        <div class="w-px h-[80%] mt-2 bg-zinc-200"></div>
                    </div>

                    <!-- Description Area -->
                    <div class="lg:col-span-7 flex flex-col items-start gap-6 pt-2 lg:pt-0">
                        <p class="font-sans text-sm md:text-base lg:text-lg text-zinc-500 font-light leading-loose">
                            Brought to life by the award-winning team at <a href="https://www.sasazawa.jp/villa/" target="_blank" rel="noopener noreferrer" class="text-zinc-800 border-b border-zinc-300 hover:border-zinc-800 transition-colors pb-0.5">Sasazawa Construction</a>, the estate reflects decades of mastery in luxury villa design. Every detail is meticulously drafted to harmonize with Karuizawa's distinct seasons, blending modern elegance with the raw, lived-in warmth of a true home.
                        </p>
                    </div>

                </div>
                
            </div>
        </section>

        <!-- ========================================== -->
        <!-- IMAGE GALLERY                              -->
        <!-- ========================================== -->
        <section id="gallery" class="px-6 md:px-12 py-24 md:py-32 lg:py-40 max-w-[100rem] mx-auto border-t border-zinc-200 relative">
            
            <div class="reveal-el mb-8 md:mb-12 lg:mb-20">
                <span class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400 mb-6 block">The Gallery</span>
            </div>

            <div class="reveal-el grid grid-cols-1 xl:grid-cols-12 gap-4 md:gap-6 xl:gap-12 items-stretch w-full">
                
                <!-- Main Featured Image -->
                <button id="main-gallery-container" class="group xl:col-span-7 w-full relative aspect-[4/3] xl:aspect-[3/2] bg-zinc-50 overflow-hidden rounded-xl border border-zinc-200 cursor-pointer p-0 text-left focus:outline-none">
                    <img id="main-gallery-image" src={img0_1.src} alt="Gallery Image" class="w-full h-full object-cover xl:absolute xl:inset-0 transition-all duration-300 ease-in-out opacity-100 select-none group-hover:scale-[1.02]" loading="lazy" decoding="async"/>
                    
                    <!-- Mobile Swipe Indicator -->
                    <div id="swipe-indicator" class="xl:hidden absolute bottom-4 md:bottom-6 left-1/2 -translate-x-1/2 z-20 pointer-events-none transition-opacity duration-500">
                        <span class="inline-block bg-zinc-900/60 backdrop-blur-sm text-white px-4 py-2 rounded-full font-sans text-[9px] font-medium tracking-widest uppercase">
                              Swipe 
                        </span>
                    </div>
                </button>

                <!-- Mobile Thumbnail Track -->
                <div class="xl:hidden w-full relative carousel-blur overflow-hidden">
                    <div id="mobile-thumb-scroll" class="flex gap-2 md:gap-3 overflow-x-auto snap-x snap-mandatory scrollbar-hide py-2 px-[5vw]">
                        {galleryImages.map((img, index) => (
                            <button class={`gallery-thumb mobile-thumb group flex-none w-[28vw] md:w-[22vw] aspect-square bg-zinc-50 border border-zinc-200 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none ring-0 snap-center ${index === 0 ? 'active' : ''}`} data-index={index} data-src={img.src.src} aria-label={`View ${img.label}`}>
                                <Image src={img.src} width={300} alt={`Thumbnail ${index + 1}`} class="w-full h-full object-cover pointer-events-none" />
                            </button>
                        ))}
                    </div>
                </div>

                <!-- Desktop Grid -->
                <div class="hidden xl:grid xl:col-span-5 w-full grid-cols-4 gap-3 content-start">
                    {galleryImages.map((img, index) => (
                        <button class={`gallery-thumb desktop-thumb group w-full aspect-square bg-zinc-50 border border-zinc-200 rounded-xl overflow-hidden relative cursor-pointer focus:outline-none ring-0 ${index === 0 ? 'active' : ''}`} data-index={index} data-src={img.src.src} aria-label={`View ${img.label}`}>
                            <Image src={img.src} width={300} alt={`Thumbnail ${index + 1}`} class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110 pointer-events-none" />
                        </button>
                    ))}
                </div>

            </div>
        </section>

        <!-- ========================================== -->
        <!-- PROPERTY OVERVIEW & LOCATION               -->
        <!-- ========================================== -->
        <section id="area" class="px-6 py-24 md:py-32 lg:py-48 max-w-4xl mx-auto border-t border-zinc-200">
            <div class="reveal-el text-center mb-12 md:mb-16 lg:mb-24">
                <span class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400 mb-6 block">Overview</span>
                <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-light text-zinc-800 tracking-wide">Property Details</h2>
            </div>

            <div class="flex flex-col border-t border-zinc-200">
                
                <!-- Address & Map -->
                <div class="reveal-el flex flex-col md:flex-row py-6 md:py-8 border-b border-zinc-200 gap-2 md:gap-8">
                    <div class="font-sans text-xs font-medium tracking-widest uppercase text-zinc-400 md:w-1/3 pt-1">Address</div>
                    <div class="flex flex-col gap-6 md:w-2/3">
                        <div class="font-sans text-sm md:text-base lg:text-lg text-zinc-800 font-light leading-loose flex flex-col gap-1">
