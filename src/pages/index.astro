---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="HC Property | Exclusive Residence">
	<Navigation />
	
	<main class="w-full tracking-normal leading-loose pt-20 md:pt-24">
		
		<section class="relative w-full px-6 md:px-12 py-16 md:py-24 max-w-[100rem] mx-auto flex flex-col gap-12 md:gap-16">
			<div class="flex flex-col items-center text-center max-w-4xl mx-auto mt-8 md:mt-12">
				<span class="hero-reveal font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 mb-6 block">
					Kutchan, Hokkaido
				</span>
				<h1 class="hero-reveal font-serif text-5xl md:text-7xl lg:text-8xl font-light text-zinc-800 tracking-tight leading-none mb-8">
					A sanctuary of minimalist purity.
				</h1>
				<p class="hero-reveal font-sans text-base md:text-lg text-zinc-500 max-w-2xl font-light leading-loose">
					Discover an exclusive retreat designed to blend seamlessly with the alpine landscapes of Japan. A masterclass in space, light, and silence.
				</p>
			</div>
			<div class="hero-reveal w-full aspect-video lg:aspect-[21/9] bg-zinc-100 overflow-hidden">
				<img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?ixlib=rb-4.0.3&auto=format&fit=crop&w=2500&q=80" alt="Exterior view of the luxury property" class="w-full h-full object-cover" loading="eager" decoding="async"/>
			</div>
		</section>

		<section id="concept" class="px-6 py-32 md:py-48 max-w-4xl mx-auto text-center">
			<span class="reveal-el font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 mb-8 block">The Concept</span>
			<h2 class="reveal-el font-serif text-4xl md:text-6xl font-light text-zinc-800 tracking-wide mb-16 leading-tight">
				A seamless dialogue <br class="hidden md:block"/> between nature and architecture.
			</h2>
			<div class="reveal-el font-sans text-zinc-500 font-light leading-loose flex flex-col gap-8 text-left md:text-center text-base md:text-lg max-w-3xl mx-auto">
				<p>Inspired by the serenity of Kutchan's ancient forests, this residence is designed as an instrument for experiencing nature. The architecture does not impose upon the landscape; rather, it frames it, allowing the shifting seasons to become the primary artwork of the home.</p>
				<p>By stripping away the superfluous, we create a space where time slows down. A return to the essential, where light, texture, and silence elevate the everyday into something profound.</p>
			</div>
		</section>

		<section id="architecture" class="px-6 md:px-12 py-24 md:py-32 max-w-[100rem] mx-auto">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-24 items-center">
				<div class="reveal-el flex flex-col gap-6 lg:px-8">
					<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400">Architecture</span>
					<h3 class="font-serif text-3xl md:text-4xl font-light text-zinc-800">Unobstructed Views</h3>
					<p class="font-sans text-base text-zinc-500 font-light leading-loose">Floor-to-ceiling triple-glazed glass spans the entire living area, framing the dramatic silhouettes of Mount Yotei. The architecture ensures you are always connected to the changing light.</p>
				</div>
				<div class="reveal-el w-full aspect-[4/3] bg-zinc-100 overflow-hidden">
					<img src="https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?ixlib=rb-4.0.3&auto=format&fit=crop&w=1600&q=80" alt="Interior living space" class="w-full h-full object-cover" loading="lazy" decoding="async"/>
				</div>

				<div class="reveal-el w-full aspect-[4/3] bg-zinc-100 overflow-hidden md:order-last">
					<img src="https://images.unsplash.com/photo-1449844908441-8829872d2607?ixlib=rb-4.0.3&auto=format&fit=crop&w=1600&q=80" alt="Architectural detail" class="w-full h-full object-cover" loading="lazy" decoding="async"/>
				</div>
				<div class="reveal-el flex flex-col gap-6 lg:px-8 md:order-first">
					<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400">Materials</span>
					<h3 class="font-serif text-3xl md:text-4xl font-light text-zinc-800">Raw & Refined</h3>
					<p class="font-sans text-base text-zinc-500 font-light leading-loose">A curated palette of locally sourced volcanic stone and weathered cedar. Materials chosen for their longevity and their ability to age with grace alongside the Hokkaido seasons.</p>
				</div>
			</div>
		</section>

		<section id="architect" class="px-6 md:px-12 py-24 md:py-32 max-w-[100rem] mx-auto border-t border-zinc-100">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24 items-start">
				
				<div class="reveal-el flex flex-col gap-8 lg:col-span-5 lg:sticky lg:top-40">
					<div>
						<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 mb-4 block">The Masterplan</span>
						<h2 class="font-serif text-3xl md:text-5xl font-light text-zinc-800 tracking-wide">Architectural Vision.</h2>
					</div>
					<div class="flex flex-col gap-6 font-sans text-base text-zinc-500 font-light leading-loose">
						<p>Designed to honor the regional heritage, the masterplan integrates the residence flawlessly into its natural topography. Every angle is meticulously calculated to maximize winter sunlight and frame the surrounding alpine landscape.</p>
						<p>The layout emphasizes a fluid transition between indoor warmth and outdoor wilderness, ensuring complete privacy while offering expansive, open-concept living spaces tailored for sophisticated entertaining.</p>
					</div>
					<div class="pt-6 mt-2 border-t border-zinc-100">
						<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-800 block mb-1">Lead Architect</span>
						<span class="font-sans text-sm text-zinc-500 font-light">Design Studio Hokkaido</span>
					</div>
				</div>

				<div class="lg:col-span-7 flex flex-col gap-12 md:gap-16">
					<div class="reveal-el flex flex-col gap-4">
						<div class="w-full aspect-[4/3] md:aspect-[16/10] bg-zinc-100 overflow-hidden">
							<img src="https://unsplash.com/photos/Vew4xyLkpdY/download?w=1600" alt="Lead architect sketching" class="w-full h-full object-cover grayscale" loading="lazy" decoding="async"/>
						</div>
						<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 text-center md:text-left">Design Process & Iteration</span>
					</div>
					
					<div class="reveal-el flex flex-col gap-4">
						<div class="w-full aspect-[4/3] md:aspect-[16/10] bg-zinc-100 overflow-hidden">
							<img src="https://unsplash.com/photos/1hSh1aDG6Mg/download?w=1600" alt="Architectural elevations" class="w-full h-full object-cover grayscale opacity-80 mix-blend-multiply" loading="lazy" decoding="async"/>
						</div>
						<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 text-center md:text-left">Original Elevations & Floor Plan</span>
					</div>
				</div>

			</div>
		</section>

		<section id="gallery" class="py-24 md:py-32 border-t border-zinc-100 overflow-hidden">
			
			<div class="px-6 md:px-12 max-w-[100rem] mx-auto mb-10 md:mb-16 flex justify-between items-end">
				<div class="reveal-el">
					<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 mb-6 block">The Gallery</span>
					<h2 class="font-serif text-3xl md:text-5xl font-light text-zinc-800 tracking-wide">A visual exploration.</h2>
				</div>
				
				<div class="hidden md:flex gap-4 reveal-el">
					<button id="gal-prev" class="w-12 h-12 rounded-full border border-zinc-200 flex items-center justify-center hover:border-zinc-800 hover:bg-zinc-800 hover:text-white transition-all cursor-pointer text-zinc-800 focus:outline-none" aria-label="Previous image">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
					</button>
					<button id="gal-next" class="w-12 h-12 rounded-full border border-zinc-200 flex items-center justify-center hover:border-zinc-800 hover:bg-zinc-800 hover:text-white transition-all cursor-pointer text-zinc-800 focus:outline-none" aria-label="Next image">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
					</button>
				</div>
			</div>

			<div class="reveal-el w-full pl-6 md:pl-12 overflow-hidden">
				<div id="gallery-track" class="flex gap-4 md:gap-8 w-max will-change-transform cursor-grab active:cursor-grabbing">
					
					<div class="gallery-item shrink-0 w-[85vw] md:w-[70vw] lg:w-[60vw] aspect-[4/3] md:aspect-[16/9] bg-zinc-100 relative group">
						<img src="https://images.unsplash.com/photo-1600607687920-4e2a09cf159d?ixlib=rb-4.0.3&auto=format&fit=crop&w=2500&q=80" alt="Living room" class="w-full h-full object-cover pointer-events-none select-none" loading="lazy" decoding="async"/>
						<div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-black/60 to-transparent pointer-events-none"></div>
						<span class="absolute bottom-6 left-6 md:bottom-8 md:left-8 font-sans text-xs tracking-[0.2em] uppercase text-white pointer-events-none">Living Space</span>
					</div>

					<div class="gallery-item shrink-0 w-[85vw] md:w-[70vw] lg:w-[60vw] aspect-[4/3] md:aspect-[16/9] bg-zinc-100 relative group">
						<img src="https://unsplash.com/photos/5a0JBpFl22U/download?w=2500" alt="Kitchen" class="w-full h-full object-cover pointer-events-none select-none" loading="lazy" decoding="async"/>
						<div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-black/60 to-transparent pointer-events-none"></div>
						<span class="absolute bottom-6 left-6 md:bottom-8 md:left-8 font-sans text-xs tracking-[0.2em] uppercase text-white pointer-events-none">The Kitchen</span>
					</div>

					<div class="gallery-item shrink-0 w-[85vw] md:w-[70vw] lg:w-[60vw] aspect-[4/3] md:aspect-[16/9] bg-zinc-100 relative group">
						<img src="https://images.unsplash.com/photo-1600607686527-6fb886090705?ixlib=rb-4.0.3&auto=format&fit=crop&w=2500&q=80" alt="Formal Dining" class="w-full h-full object-cover pointer-events-none select-none" loading="lazy" decoding="async"/>
						<div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-black/60 to-transparent pointer-events-none"></div>
						<span class="absolute bottom-6 left-6 md:bottom-8 md:left-8 font-sans text-xs tracking-[0.2em] uppercase text-white pointer-events-none">Formal Dining</span>
					</div>

					<div class="gallery-item shrink-0 w-[85vw] md:w-[70vw] lg:w-[60vw] aspect-[4/3] md:aspect-[16/9] bg-zinc-100 relative group">
						<img src="https://images.unsplash.com/photo-1616594039964-ae9021a400a0?ixlib=rb-4.0.3&auto=format&fit=crop&w=2500&q=80" alt="Master Suite" class="w-full h-full object-cover pointer-events-none select-none" loading="lazy" decoding="async"/>
						<div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-black/60 to-transparent pointer-events-none"></div>
						<span class="absolute bottom-6 left-6 md:bottom-8 md:left-8 font-sans text-xs tracking-[0.2em] uppercase text-white pointer-events-none">The Suite</span>
					</div>

					<div class="gallery-item shrink-0 w-[85vw] md:w-[70vw] lg:w-[60vw] aspect-[4/3] md:aspect-[16/9] bg-zinc-100 relative group">
						<img src="https://images.unsplash.com/photo-1600566752355-35792bedcfea?ixlib=rb-4.0.3&auto=format&fit=crop&w=2500&q=80" alt="Master Bath" class="w-full h-full object-cover pointer-events-none select-none" loading="lazy" decoding="async"/>
						<div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-black/60 to-transparent pointer-events-none"></div>
						<span class="absolute bottom-6 left-6 md:bottom-8 md:left-8 font-sans text-xs tracking-[0.2em] uppercase text-white pointer-events-none">Master Bath</span>
					</div>

					<div class="gallery-item shrink-0 w-[85vw] md:w-[70vw] lg:w-[60vw] aspect-[4/3] md:aspect-[16/9] bg-zinc-100 relative group">
						<img src="https://images.unsplash.com/photo-1584622650111-993a426fbf0a?ixlib=rb-4.0.3&auto=format&fit=crop&w=2500&q=80" alt="Private Onsen" class="w-full h-full object-cover pointer-events-none select-none" loading="lazy" decoding="async"/>
						<div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-black/60 to-transparent pointer-events-none"></div>
						<span class="absolute bottom-6 left-6 md:bottom-8 md:left-8 font-sans text-xs tracking-[0.2em] uppercase text-white pointer-events-none">Private Onsen</span>
					</div>

					<div class="gallery-item shrink-0 w-[85vw] md:w-[70vw] lg:w-[60vw] aspect-[4/3] md:aspect-[16/9] bg-zinc-100 relative group">
						<img src="https://images.unsplash.com/photo-1510798831971-661eb04b3739?ixlib=rb-4.0.3&auto=format&fit=crop&w=2500&q=80" alt="Winter Architecture" class="w-full h-full object-cover pointer-events-none select-none" loading="lazy" decoding="async"/>
						<div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-black/60 to-transparent pointer-events-none"></div>
						<span class="absolute bottom-6 left-6 md:bottom-8 md:left-8 font-sans text-xs tracking-[0.2em] uppercase text-white pointer-events-none">Winter Architecture</span>
					</div>

				</div>
			</div>
		</section>

		<section id="area" class="px-6 py-24 md:py-32 max-w-4xl mx-auto border-t border-zinc-100">
			<div class="reveal-el text-center mb-16 md:mb-24">
				<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 mb-6 block">The Area</span>
				<h2 class="font-serif text-3xl md:text-5xl font-light text-zinc-800 tracking-wide">Kutchan & Niseko</h2>
			</div>

			<div class="flex flex-col border-t border-zinc-100">
				<div class="reveal-el flex flex-col md:flex-row py-6 md:py-8 border-b border-zinc-100 gap-2 md:gap-8">
					<div class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 md:w-1/3 pt-1">Location</div>
					<div class="font-sans text-base md:text-lg text-zinc-800 font-light md:w-2/3 leading-loose">Kutchan, Hokkaido, Japan</div>
				</div>
				<div class="reveal-el flex flex-col md:flex-row py-6 md:py-8 border-b border-zinc-100 gap-2 md:gap-8">
					<div class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 md:w-1/3 pt-1">Winter Access</div>
					<div class="font-sans text-base md:text-lg text-zinc-800 font-light md:w-2/3 leading-loose">Minutes from the world-class powder snow of Grand Hirafu and Niseko Hanazono resorts.</div>
				</div>
				<div class="reveal-el flex flex-col md:flex-row py-6 md:py-8 border-b border-zinc-100 gap-2 md:gap-8">
					<div class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 md:w-1/3 pt-1">Surroundings</div>
					<div class="font-sans text-base md:text-lg text-zinc-800 font-light md:w-2/3 leading-loose">Immersed in serene alpine forests with commanding views of Mount Yotei.</div>
				</div>
			</div>
		</section>

		<section id="inquire" class="px-6 py-32 md:py-48 max-w-3xl mx-auto border-t border-zinc-100">
			<div class="reveal-el text-center mb-16 md:mb-24">
				<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 mb-6 block">Private Viewing</span>
				<h2 class="font-serif text-3xl md:text-5xl font-light text-zinc-800 tracking-wide mb-8">Inquire about this property</h2>
			</div>

			<form class="flex flex-col gap-12">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-12">
					<div class="reveal-el flex flex-col gap-3">
						<label for="name" class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400">Name</label>
						<input type="text" id="name" class="w-full bg-transparent border-b border-zinc-200 py-2 font-sans text-lg font-light focus:outline-none focus:border-zinc-800 transition-colors rounded-none" required />
					</div>
					<div class="reveal-el flex flex-col gap-3">
						<label for="email" class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400">Email</label>
						<input type="email" id="email" class="w-full bg-transparent border-b border-zinc-200 py-2 font-sans text-lg font-light focus:outline-none focus:border-zinc-800 transition-colors rounded-none" required />
					</div>
				</div>
				<div class="reveal-el flex flex-col gap-3">
					<label for="message" class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400">Message</label>
					<textarea id="message" rows="4" class="w-full bg-transparent border-b border-zinc-200 py-2 font-sans text-lg font-light focus:outline-none focus:border-zinc-800 transition-colors resize-none rounded-none"></textarea>
				</div>
				<button type="submit" class="reveal-el self-center mt-8 bg-zinc-800 text-white font-sans text-xs font-medium tracking-[0.2em] uppercase px-12 py-5 hover:bg-zinc-700 transition-colors w-full md:w-auto cursor-pointer">
					Submit Inquiry
				</button>
			</form>
		</section>

	</main>
	
	<div class="reveal-el">
		<Footer />
	</div>
</Layout>

<script>
	// --- BULLETPROOF 3X CLONE INFINITE CAROUSEL ---
	document.addEventListener('DOMContentLoaded', () => {
		const track = document.getElementById('gallery-track');
		const prevBtn = document.getElementById('gal-prev');
		const nextBtn = document.getElementById('gal-next');
		
		if (!track || !prevBtn || !nextBtn) return;

		const originalItems = Array.from(track.querySelectorAll('.gallery-item'));
		const totalOriginal = originalItems.length;

		// 1. Create a seamlessly massive track by cloning the set before and after
		originalItems.forEach(item => {
			const clone = item.cloneNode(true);
			track.appendChild(clone);
		});

		originalItems.slice().reverse().forEach(item => {
			const clone = item.cloneNode(true);
			track.insertBefore(clone, track.firstElementChild);
		});

		let currentIndex = totalOriginal; // Start exactly at the first original image in the middle
		let isAnimating = false;
		let moveDistance = 0;

		// 2. Calculate accurate layout measurements
		const updateDimensions = () => {
			const firstItem = track.firstElementChild as HTMLElement;
			if (!firstItem) return;
			const itemWidth = firstItem.getBoundingClientRect().width;
			const gap = parseFloat(window.getComputedStyle(track).gap) || 0;
			moveDistance = itemWidth + gap;

			// Instantly lock to the exact right pixel without animating
			track.style.transition = 'none';
			track.style.transform = `translate3d(-${currentIndex * moveDistance}px, 0, 0)`;
		};

		// 3. The Core Movement Engine
		const moveTo = (index: number, animate = true) => {
			if (isAnimating && animate) return;

			currentIndex = index;

			if (animate) {
				isAnimating = true;
				// This is the luxurious, heavy "Seren Collective" deceleration curve
				track.style.transition = 'transform 0.7s cubic-bezier(0.25, 1, 0.5, 1)';
			} else {
				track.style.transition = 'none';
			}

			track.style.transform = `translate3d(-${currentIndex * moveDistance}px, 0, 0)`;

			if (animate) {
				setTimeout(() => {
					isAnimating = false;
					
					// TELEPORTATION: If we reach the clones on either side, teleport back to the center seamlessly
					if (currentIndex < totalOriginal) {
						moveTo(currentIndex + totalOriginal, false);
					} else if (currentIndex >= totalOriginal * 2) {
						moveTo(currentIndex - totalOriginal, false);
					}
				}, 700); // Matches transition duration perfectly
			}
		};

		// Setup bindings
		updateDimensions();
		window.addEventListener('resize', updateDimensions);

		nextBtn.addEventListener('click', () => moveTo(currentIndex + 1));
		prevBtn.addEventListener('click', () => moveTo(currentIndex - 1));

		// Mobile Swipe Touch Support
		let touchStartX = 0;
		let touchEndX = 0;

		track.addEventListener('touchstart', e => {
			touchStartX = e.changedTouches[0].screenX;
		}, { passive: true });

		track.addEventListener('touchend', e => {
			touchEndX = e.changedTouches[0].screenX;
			if (touchStartX - touchEndX > 40) moveTo(currentIndex + 1); // Swiped Left (Next)
			if (touchEndX - touchStartX > 40) moveTo(currentIndex - 1); // Swiped Right (Prev)
		}, { passive: true });
	});
</script>