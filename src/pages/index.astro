---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

import { Image } from 'astro:assets';

// Section Images
import imgHero from '../assets/gallery/hero.jpeg';
import imgLiving from '../assets/gallery/living.jpeg';
import imgSuite from '../assets/gallery/suite.jpeg';
import imgFirepit from '../assets/gallery/firepit1.jpeg'; // Updated to firepit1.jpeg
import imgFloorplan1 from '../assets/gallery/floorplan1.jpeg';
import imgFloorplan2 from '../assets/gallery/floorplan2.jpeg';

// New 16-Image Gallery Imports
import img1 from '../assets/gallery/1.jpeg';
import img2 from '../assets/gallery/2.jpeg';
import img3 from '../assets/gallery/3.jpeg';
import img4 from '../assets/gallery/4.jpeg';
import img5 from '../assets/gallery/5.jpeg';
import img6 from '../assets/gallery/6.jpeg';
import img7 from '../assets/gallery/7.jpeg';
import img8 from '../assets/gallery/8.jpeg';
import img9 from '../assets/gallery/9.jpeg';
import img10 from '../assets/gallery/10.jpeg';
import img11 from '../assets/gallery/11.jpeg';
import img12 from '../assets/gallery/12.jpeg';
import img13 from '../assets/gallery/13.jpeg';
import img14 from '../assets/gallery/14.jpeg';
import img15 from '../assets/gallery/15.jpeg';
import img16 from '../assets/gallery/16.jpeg';
---

<Layout title="Seren Collective MAPLE | Karuizawa">
	<Navigation />
	
	<main class="w-full tracking-normal leading-loose">
		
		<!-- EDITORIAL BANNER HERO -->
		<section id="hero-section" class="relative w-full h-[35svh] min-h-[320px] md:h-[35svh] md:min-h-[400px] lg:h-[100svh] lg:min-h-[700px] flex flex-col overflow-hidden bg-zinc-950">
			
			<div class="absolute inset-0 w-full h-full">
				<Image src={imgHero} alt="Exterior view of Seren Collective Maple" class="w-full h-full object-cover opacity-90" loading="eager" fetchpriority="high" />
				<div class="absolute inset-0 bg-gradient-to-t from-zinc-950/80 md:from-zinc-950/60 lg:from-zinc-950/50 via-transparent to-black/30"></div>
			</div>

			<div class="relative z-10 flex flex-col items-start justify-end text-left px-6 md:px-12 w-full max-w-[100rem] mx-auto h-full pb-8 md:pb-12 lg:pb-32">
				<h1 class="hero-reveal font-sans text-2xl md:text-3xl lg:text-5xl font-light tracking-[0.15em] text-white drop-shadow-md flex items-center">
					Karuizawa <span class="mx-3 md:mx-4 font-extralight text-white/50 text-xl md:text-2xl lg:text-4xl">|</span> 轻井泽
				</h1>
			</div>

			<div class="hidden lg:flex absolute bottom-12 right-12 z-10 hero-reveal flex-col items-center gap-4">
				<span class="font-sans text-[9px] tracking-[0.3em] uppercase text-white/60" style="writing-mode: vertical-rl;">Scroll</span>
				<div class="w-px h-12 bg-white/20 relative overflow-hidden">
					<div class="absolute top-0 left-0 w-full h-1/2 bg-white animate-scroll-drop"></div>
				</div>
			</div>
		</section>

		<!-- CONCEPT SECTION -->
		<section id="concept" class="px-6 py-24 md:py-32 lg:py-48 max-w-4xl mx-auto text-center">
			<span class="reveal-el font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 mb-8 block">The Estate</span>
			<h2 class="reveal-el font-serif text-3xl md:text-5xl lg:text-6xl font-light text-zinc-800 tracking-wide mb-12 md:mb-16 leading-tight">
				A sanctuary divided, <br class="hidden md:block"/> yet perfectly unified.
			</h2>
			<div class="reveal-el font-sans text-zinc-500 font-light leading-loose flex flex-col gap-6 md:gap-8 text-left md:text-center text-sm md:text-base lg:text-lg max-w-3xl mx-auto">
				<p>Set within a deeply forested enclave of Karuizawa, this expansive residence is ingeniously designed as two distinct structures—a main house and a guest house—connected seamlessly by an elegant hallway.</p>
				<p>This intelligent layout allows the property to function flawlessly as a single, grand estate for large gatherings, or it can be secured to provide absolute privacy and independence for both hosts and guests.</p>
			</div>
		</section>

		<!-- FEATURES SECTION -->
		<section id="architecture" class="px-6 md:px-12 py-16 md:py-24 lg:py-32 max-w-[100rem] mx-auto">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center">
				
				<div class="reveal-el flex flex-col gap-4 md:gap-6 lg:px-8 order-1">
					<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400">Accommodations</span>
					<h3 class="font-serif text-2xl md:text-3xl lg:text-4xl font-light text-zinc-800">Seven Private Suites</h3>
					<p class="font-sans text-sm md:text-base text-zinc-500 font-light leading-loose">The estate accommodates family and guests with uncompromising comfort. The main residence features four spacious bedrooms, while the guest house offers three. Crucially, every single bedroom in the estate is complemented by its own private ensuite bathroom.</p>
				</div>
				<div class="reveal-el w-full aspect-[4/3] bg-zinc-100 overflow-hidden rounded-xl order-2">
					<Image src={imgSuite} alt="Private Suite Interior" class="w-full h-full object-cover" />
				</div>

				<div class="reveal-el flex flex-col gap-4 md:gap-6 lg:px-8 order-3 lg:order-4">
					<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400">Wellness & Leisure</span>
					<h3 class="font-serif text-2xl md:text-3xl lg:text-4xl font-light text-zinc-800">Private Spa & Firepit</h3>
					<p class="font-sans text-sm md:text-base text-zinc-500 font-light leading-loose">The second floor of the main house is dedicated to wellness, featuring a private spa with dual large soaking tubs and a custom sauna. Outside, an expansive wooden deck centers around a sunken firepit—the perfect setting for evening relaxation under the forest canopy.</p>
				</div>
				<div class="reveal-el w-full aspect-[4/3] bg-zinc-100 overflow-hidden rounded-xl order-4 lg:order-3">
					<Image src={imgFirepit} alt="Wellness and Deck Firepit" class="w-full h-full object-cover" />
				</div>

			</div>
		</section>

		<!-- FLOORPLAN SECTION -->
		<section id="floorplan" class="px-6 md:px-12 py-16 md:py-24 lg:py-32 max-w-[100rem] mx-auto border-t border-zinc-100">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24 items-start">
				
				<div class="reveal-el flex flex-col gap-6 md:gap-8 lg:col-span-4 lg:sticky lg:top-40">
					<div>
						<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 mb-4 block">The Masterplan</span>
						<h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-light text-zinc-800 tracking-wide">Structural Harmony.</h2>
					</div>
					<div class="flex flex-col gap-4 md:gap-6 font-sans text-sm md:text-base text-zinc-500 font-light leading-loose">
						<p>The first floor establishes the estate's dual-wing concept. A central gallery bridges the main residence and the guest house, wrapping around a landscaped garden and expansive outdoor terrace.</p>
						<p>The second floor is dedicated entirely to privacy and wellness. It houses the seven ensuite bedrooms, alongside the main house's dedicated spa and sauna retreat.</p>
					</div>
				</div>

				<div class="lg:col-span-8 flex flex-col gap-12 md:gap-16 lg:gap-24">
					<div class="reveal-el flex flex-col gap-6">
						<div class="w-full bg-zinc-50 p-4 md:p-8 lg:p-12 rounded-xl flex items-center justify-center border border-zinc-100 shadow-sm">
							<Image src={imgFloorplan1} alt="First Floor Plan" class="w-full h-auto object-contain mix-blend-multiply opacity-80" />
						</div>
						<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 text-center lg:text-left">
							First Floor: Living & Gathering Spaces
						</span>
					</div>
					
					<div class="reveal-el flex flex-col gap-6">
						<div class="w-full bg-zinc-50 p-4 md:p-8 lg:p-12 rounded-xl flex items-center justify-center border border-zinc-100 shadow-sm">
							<Image src={imgFloorplan2} alt="Second Floor Plan" class="w-full h-auto object-contain mix-blend-multiply opacity-80" />
						</div>
						<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 text-center lg:text-left">
							Second Floor: Private Suites & Spa
						</span>
					</div>
				</div>

			</div>
		</section>

		<!-- EXPANDED 16-IMAGE GALLERY -->
		<section id="gallery" class="px-6 md:px-12 py-16 md:py-24 lg:py-32 max-w-[100rem] mx-auto border-t border-zinc-100">
			
			<div class="reveal-el mb-8 md:mb-12 lg:mb-20">
				<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 mb-6 block">The Gallery</span>
			</div>

			<div class="reveal-el flex flex-col lg:flex-row justify-between items-start gap-6 md:gap-8 lg:gap-16 w-full">
				
				<div id="main-gallery-container" class="w-full lg:w-[55%] relative aspect-[4/3] md:aspect-[16/11] bg-zinc-100 overflow-hidden rounded-xl shadow-sm">
					<img id="main-gallery-image" src={img1.src} alt="Gallery Image" class="w-full h-full object-cover transition-opacity duration-500 ease-in-out opacity-100" loading="lazy" decoding="async"/>
				</div>

				<div class="w-full lg:w-[40%] grid grid-cols-4 gap-2 md:gap-3 lg:gap-4 content-start pt-1">
					<button class="gallery-thumb active w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300 ring-0" data-src={img1.src} aria-label="View Image 1">
						<Image src={img1} width={300} alt="Thumbnail 1" class="w-full h-full object-cover pointer-events-none" />
					</button>
					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300 ring-0" data-src={img2.src} aria-label="View Image 2">
						<Image src={img2} width={300} alt="Thumbnail 2" class="w-full h-full object-cover pointer-events-none" />
					</button>
					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300 ring-0" data-src={img3.src} aria-label="View Image 3">
						<Image src={img3} width={300} alt="Thumbnail 3" class="w-full h-full object-cover pointer-events-none" />
					</button>
					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300 ring-0" data-src={img4.src} aria-label="View Image 4">
						<Image src={img4} width={300} alt="Thumbnail 4" class="w-full h-full object-cover pointer-events-none" />
					</button>
					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300 ring-0" data-src={img5.src} aria-label="View Image 5">
						<Image src={img5} width={300} alt="Thumbnail 5" class="w-full h-full object-cover pointer-events-none" />
					</button>
					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300 ring-0" data-src={img6.src} aria-label="View Image 6">
						<Image src={img6} width={300} alt="Thumbnail 6" class="w-full h-full object-cover pointer-events-none" />
					</button>
					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300 ring-0" data-src={img7.src} aria-label="View Image 7">
						<Image src={img7} width={300} alt="Thumbnail 7" class="w-full h-full object-cover pointer-events-none" />
					</button>
					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300 ring-0" data-src={img8.src} aria-label="View Image 8">
						<Image src={img8} width={300} alt="Thumbnail 8" class="w-full h-full object-cover pointer-events-none" />
					</button>
					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300 ring-0" data-src={img9.src} aria-label="View Image 9">
						<Image src={img9} width={300} alt="Thumbnail 9" class="w-full h-full object-cover pointer-events-none" />
					</button>
					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300 ring-0" data-src={img10.src} aria-label="View Image 10">
						<Image src={img10} width={300} alt="Thumbnail 10" class="w-full h-full object-cover pointer-events-none" />
					</button>
					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300 ring-0" data-src={img11.src} aria-label="View Image 11">
						<Image src={img11} width={300} alt="Thumbnail 11" class="w-full h-full object-cover pointer-events-none" />
					</button>
					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300 ring-0" data-src={img12.src} aria-label="View Image 12">
						<Image src={img12} width={300} alt="Thumbnail 12" class="w-full h-full object-cover pointer-events-none" />
					</button>
					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300 ring-0" data-src={img13.src} aria-label="View Image 13">
						<Image src={img13} width={300} alt="Thumbnail 13" class="w-full h-full object-cover pointer-events-none" />
					</button>
					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300 ring-0" data-src={img14.src} aria-label="View Image 14">
						<Image src={img14} width={300} alt="Thumbnail 14" class="w-full h-full object-cover pointer-events-none" />
					</button>
					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300 ring-0" data-src={img15.src} aria-label="View Image 15">
						<Image src={img15} width={300} alt="Thumbnail 15" class="w-full h-full object-cover pointer-events-none" />
					</button>
					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300 ring-0" data-src={img16.src} aria-label="View Image 16">
						<Image src={img16} width={300} alt="Thumbnail 16" class="w-full h-full object-cover pointer-events-none" />
					</button>
				</div>
			</div>
		</section>

		<!-- RESTORED TEXT-ONLY AREA SECTION -->
		<section id="area" class="px-6 py-16 md:py-24 lg:py-32 max-w-4xl mx-auto border-t border-zinc-100">
			<div class="reveal-el text-center mb-12 md:mb-16 lg:mb-24">
				<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 mb-6 block">The Area</span>
				<h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-light text-zinc-800 tracking-wide">Karuizawa</h2>
			</div>

			<div class="flex flex-col border-t border-zinc-100">
				
				<div class="reveal-el flex flex-col md:flex-row py-6 md:py-8 border-b border-zinc-100 gap-2 md:gap-8">
					<div class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 md:w-1/3 pt-1">Address</div>
					<div class="font-sans text-sm md:text-base lg:text-lg text-zinc-800 font-light md:w-2/3 leading-loose flex flex-col gap-1">
						<span>19-29 Seisatsuba, Oaza Nagakura, Karuizawa-machi, Kitasaku-gun, Nagano</span>
						<span class="text-xs md:text-sm text-zinc-500 font-light tracking-wide mt-1">長野県北佐久郡軽井沢町大字長倉字制札場１９－２９</span>
					</div>
				</div>

				<div class="reveal-el flex flex-col md:flex-row py-6 md:py-8 border-b border-zinc-100 gap-2 md:gap-8">
					<div class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 md:w-1/3 pt-1">Neighborhood</div>
					<div class="font-sans text-sm md:text-base lg:text-lg text-zinc-800 font-light md:w-2/3 leading-loose">
						Situated within a deeply forested area of Karuizawa, offering profound tranquility, shade, and seclusion, while maintaining convenient access to the town's refined amenities.
					</div>
				</div>
				
				<div class="reveal-el flex flex-col md:flex-row py-6 md:py-8 border-b border-zinc-100 gap-2 md:gap-8">
					<div class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 md:w-1/3 pt-1">Access</div>
					<div class="font-sans text-sm md:text-base lg:text-lg text-zinc-800 font-light md:w-2/3 leading-loose">
						Conveniently accessible via the Hokuriku Shinkansen from central Tokyo.
					</div>
				</div>

			</div>
		</section>

		<section id="inquire" class="px-6 py-24 md:py-32 lg:py-48 max-w-3xl mx-auto border-t border-zinc-100">
			<div class="reveal-el text-center mb-12 md:mb-16 lg:mb-24">
				<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 mb-6 block">Private Viewing</span>
				<h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-light text-zinc-800 tracking-wide mb-8">Inquire about this property</h2>
			</div>

			<form class="flex flex-col gap-8 md:gap-12">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
					<div class="reveal-el flex flex-col gap-2 md:gap-3">
						<label for="name" class="font-sans text-[10px] md:text-xs font-medium tracking-[0.2em] uppercase text-zinc-400">Name</label>
						<input type="text" id="name" class="w-full bg-transparent border-b border-zinc-200 py-2 font-sans text-base md:text-lg font-light focus:outline-none focus:border-zinc-800 transition-colors rounded-none" required />
					</div>
					<div class="reveal-el flex flex-col gap-2 md:gap-3">
						<label for="email" class="font-sans text-[10px] md:text-xs font-medium tracking-[0.2em] uppercase text-zinc-400">Email</label>
						<input type="email" id="email" class="w-full bg-transparent border-b border-zinc-200 py-2 font-sans text-base md:text-lg font-light focus:outline-none focus:border-zinc-800 transition-colors rounded-none" required />
					</div>
				</div>
				<div class="reveal-el flex flex-col gap-2 md:gap-3">
					<label for="message" class="font-sans text-[10px] md:text-xs font-medium tracking-[0.2em] uppercase text-zinc-400">Message</label>
					<textarea id="message" rows="4" class="w-full bg-transparent border-b border-zinc-200 py-2 font-sans text-base md:text-lg font-light focus:outline-none focus:border-zinc-800 transition-colors resize-none rounded-none"></textarea>
				</div>
				<button type="submit" class="reveal-el self-center mt-4 md:mt-8 bg-zinc-800 text-white font-sans text-[10px] md:text-xs font-medium tracking-[0.2em] uppercase px-10 md:px-12 py-4 md:py-5 hover:bg-zinc-700 transition-colors w-full md:w-auto cursor-pointer">
					Submit Inquiry
				</button>
			</form>
		</section>

	</main>
	
	<div class="reveal-el">
		<Footer />
	</div>
</Layout>

<style>
	@keyframes scrollDrop {
		0% { transform: translateY(-100%); opacity: 0; }
		50% { opacity: 1; }
		100% { transform: translateY(200%); opacity: 0; }
	}
	.animate-scroll-drop {
		animation: scrollDrop 2s cubic-bezier(0.77, 0, 0.175, 1) infinite;
	}

	.gallery-thumb {
		opacity: 0.4;
		transition: opacity 0.4s ease;
	}
	.gallery-thumb:hover {
		opacity: 0.7;
	}
	.gallery-thumb.active {
		opacity: 1;
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const mainImage = document.getElementById('main-gallery-image') as HTMLImageElement;
		const thumbnails = document.querySelectorAll('.gallery-thumb');

		if (!mainImage || thumbnails.length === 0) return;

		let isTransitioning = false;

		thumbnails.forEach(thumb => {
			thumb.addEventListener('click', () => {
				if (isTransitioning || thumb.classList.contains('active')) return;
				
				const newSrc = thumb.getAttribute('data-src');
				if (!newSrc) return;

				isTransitioning = true;

				mainImage.style.opacity = '0';

				mainImage.addEventListener('transitionend', function handler() {
					mainImage.removeEventListener('transitionend', handler);

					mainImage.src = newSrc;

					thumbnails.forEach(t => t.classList.remove('active'));
					thumb.classList.add('active');

					mainImage.onload = () => {
						mainImage.style.opacity = '1';
						isTransitioning = false; 
					};
				}, { once: true });
			});
		});
	});
</script>