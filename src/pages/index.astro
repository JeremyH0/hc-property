---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

import { Image } from 'astro:assets';

// Hero Image
import imgHeroHQ from '../assets/gallery/hero-hq.jpeg';

import imgSuite from '../assets/gallery/suite.jpeg';
import imgFirepit from '../assets/gallery/firepit1.jpeg'; 
import imgFloorplan1 from '../assets/gallery/floorplan1.jpeg';
import imgFloorplan2 from '../assets/gallery/floorplan2.jpeg';

// High Definition Floorplans
import imgFloorplan1HD from '../assets/gallery/floorplan1hd.jpeg';
import imgFloorplan2HD from '../assets/gallery/floorplan2hd.jpeg';

// New 16-Image Gallery Imports
import img1 from '../assets/gallery/1.jpeg';
import img2 from '../assets/gallery/2.jpeg';
import img3 from '../assets/gallery/3.jpeg';
import img4 from '../assets/gallery/4.jpeg';
import img5 from '../assets/gallery/5.jpeg';
import img6 from '../assets/gallery/6.jpeg';
import img7 from '../assets/gallery/7.jpeg';
import img8 from '../assets/gallery/8.jpeg';
import img9 from '../assets/gallery/9.jpeg';
import img10 from '../assets/gallery/10.jpeg';
import img11 from '../assets/gallery/11.jpeg';
import img12 from '../assets/gallery/12.jpeg';
import img13 from '../assets/gallery/13.jpeg';
import img14 from '../assets/gallery/14.jpeg';
import img15 from '../assets/gallery/15.jpeg';
import img16 from '../assets/gallery/16.jpeg';

// Helper array to generate the sets effortlessly
const galleryImages = [
    { src: img1, label: "Image 1" }, { src: img2, label: "Image 2" },
    { src: img3, label: "Image 3" }, { src: img4, label: "Image 4" },
    { src: img5, label: "Image 5" }, { src: img6, label: "Image 6" },
    { src: img7, label: "Image 7" }, { src: img8, label: "Image 8" },
    { src: img9, label: "Image 9" }, { src: img10, label: "Image 10" },
    { src: img11, label: "Image 11" }, { src: img12, label: "Image 12" },
    { src: img13, label: "Image 13" }, { src: img14, label: "Image 14" },
    { src: img15, label: "Image 15" }, { src: img16, label: "Image 16" }
];
---

<Layout title="Karuizawa | 轻井泽">
    <Navigation />
    
    <main class="w-full tracking-normal leading-loose">
        
        <section id="hero-section" class="relative w-full h-[35svh] min-h-[320px] md:h-[35svh] md:min-h-[400px] lg:h-[100svh] lg:min-h-[700px] flex flex-col overflow-hidden bg-stone-950">
            
            <div class="absolute inset-0 w-full h-full">
                <Image 
                    src={imgHeroHQ} 
                    alt="Exterior view of Seren Collective Maple" 
                    widths={[768, 1280, 1920, 2560]}
                    sizes="100vw"
                    class="w-full h-full object-cover opacity-90" 
                    loading="eager" 
                    fetchpriority="high" 
                />
                <div class="absolute inset-0 bg-gradient-to-t from-stone-950/80 md:from-stone-950/60 lg:from-stone-950/50 via-transparent to-black/30"></div>
            </div>

            <div class="relative z-10 flex flex-col items-start justify-end text-left px-6 md:px-12 w-full max-w-[100rem] mx-auto h-full pb-8 md:pb-12 lg:pb-32">
                <h1 class="hero-reveal font-sans text-2xl md:text-3xl lg:text-5xl font-light tracking-[0.15em] text-white drop-shadow-md flex items-center">
                    Karuizawa <span class="mx-3 md:mx-4 font-extralight text-white/50 text-xl md:text-2xl lg:text-4xl">|</span> 轻井泽
                </h1>
            </div>

            <div class="hidden xl:flex absolute bottom-12 right-12 z-10 hero-reveal flex-col items-center gap-4">
                <span class="font-sans text-[9px] tracking-[0.3em] uppercase text-white/60" style="writing-mode: vertical-rl;">Scroll</span>
                <div class="w-px h-12 bg-white/20 relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-1/2 bg-white animate-scroll-drop"></div>
                </div>
            </div>
        </section>

        <section id="concept" class="px-6 py-24 md:py-32 lg:py-48 max-w-4xl mx-auto text-center">
            <span class="reveal-el font-sans text-xs font-medium tracking-[0.2em] uppercase text-stone-400 mb-8 block">The Estate</span>
            <h2 class="reveal-el font-serif text-3xl md:text-5xl lg:text-6xl font-light text-stone-800 tracking-wide mb-12 md:mb-16 leading-tight">
                A sanctuary divided, <br class="hidden md:block"/> yet perfectly unified.
            </h2>
            <div class="reveal-el font-sans text-stone-500 font-light leading-loose flex flex-col gap-6 md:gap-8 text-left md:text-center text-sm md:text-base lg:text-lg max-w-3xl mx-auto">
                <p>Set within a deeply forested enclave of Karuizawa, this expansive residence is ingeniously designed as two distinct structures—a main house and a guest house—connected seamlessly by an elegant hallway.</p>
                <p>This intelligent layout allows the property to function flawlessly as a single, grand estate for large gatherings, or it can be secured to provide absolute privacy and independence for both hosts and guests.</p>
            </div>
        </section>

        <section id="architecture" class="px-6 md:px-12 py-16 md:py-24 lg:py-32 max-w-[100rem] mx-auto">
            <div class="grid grid-cols-1 xl:grid-cols-2 gap-12 xl:gap-24 items-center">
                
                <div class="reveal-el flex flex-col gap-4 md:gap-6 xl:px-8 order-1">
                    <span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-stone-400">Accommodations</span>
                    <h3 class="font-serif text-2xl md:text-3xl lg:text-4xl font-light text-stone-800">Seven Private Suites</h3>
                    <p class="font-sans text-sm md:text-base text-stone-500 font-light leading-loose">The estate accommodates family and guests with uncompromising comfort. The main residence features four spacious bedrooms, while the guest house offers three. Crucially, every single bedroom in the estate is complemented by its own private ensuite bathroom.</p>
                </div>
                <div class="reveal-el w-full aspect-[4/3] bg-stone-50 overflow-hidden rounded-xl border border-stone-200 shadow-sm order-2">
                    <Image src={imgSuite} alt="Private Suite Interior" class="w-full h-full object-cover" />
                </div>

                <div class="reveal-el flex flex-col gap-4 md:gap-6 xl:px-8 order-3 xl:order-4">
                    <span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-stone-400">Wellness & Leisure</span>
                    <h3 class="font-serif text-2xl md:text-3xl lg:text-4xl font-light text-stone-800">Private Spa & Firepit</h3>
                    <p class="font-sans text-sm md:text-base text-stone-500 font-light leading-loose">The second floor of the main house is dedicated to wellness, featuring a private spa with dual large soaking tubs and a custom sauna. Outside, an expansive wooden deck centers around a sunken firepit—the perfect setting for evening relaxation under the forest canopy.</p>
                </div>
                <div class="reveal-el w-full aspect-[4/3] bg-stone-50 overflow-hidden rounded-xl border border-stone-200 shadow-sm order-4 xl:order-3">
                    <Image src={imgFirepit} alt="Wellness and Deck Firepit" class="w-full h-full object-cover" />
                </div>

            </div>
        </section>

        <section id="floorplan" class="px-6 md:px-12 py-16 md:py-24 lg:py-32 max-w-[100rem] mx-auto border-t border-stone-200">
            <div class="grid grid-cols-1 xl:grid-cols-12 gap-12 xl:gap-24 relative items-start">
                
                <div class="xl:col-span-4 xl:sticky xl:top-32 transition-all duration-300">
                    <div class="reveal-el flex flex-col gap-6 md:gap-8">
                        <div>
                            <span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-stone-400 mb-4 block">The Masterplan</span>
                            <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-light text-stone-800 tracking-wide">Structural Harmony.</h2>
                        </div>
                        <div class="flex flex-col gap-4 md:gap-6 font-sans text-sm md:text-base text-stone-500 font-light leading-loose">
                            <p>The first floor establishes the estate's dual-wing concept. A central gallery bridges the main residence and the guest house, wrapping around a landscaped garden and expansive outdoor terrace.</p>
                            <p>The second floor is dedicated entirely to privacy and wellness. It houses the seven ensuite bedrooms, alongside the main house's dedicated spa and sauna retreat.</p>
                        </div>
                    </div>
                </div>

                <div class="xl:col-span-8 flex flex-col gap-12 md:gap-16 lg:gap-24">
                    
                    <div class="reveal-el flex flex-col gap-6">
                        <button class="floorplan-trigger group w-full bg-stone-50 p-4 md:p-8 lg:p-12 rounded-xl flex items-center justify-center border border-stone-200 shadow-sm relative overflow-hidden cursor-pointer" data-index="0" data-hd-src={imgFloorplan1HD.src} data-caption="First Floor: Living & Gathering Spaces">
                            <Image src={imgFloorplan1} alt="First Floor Plan" class="w-full h-auto object-contain mix-blend-multiply opacity-80 transition-transform duration-700 ease-out group-hover:scale-105" />
                            
                            <div class="absolute inset-0 bg-white/10 backdrop-blur-[1px] opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center pointer-events-none">
                                <span class="font-sans text-[10px] md:text-xs font-medium tracking-[0.2em] uppercase text-stone-800 border border-stone-800 px-6 py-3 rounded-full bg-white/90 shadow-sm">View Floorplan</span>
                            </div>
                        </button>
                        <span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-stone-400 text-center xl:text-left">
                            First Floor: Living & Gathering Spaces
                        </span>
                    </div>
                    
                    <div class="reveal-el flex flex-col gap-6">
                        <button class="floorplan-trigger group w-full bg-stone-50 p-4 md:p-8 lg:p-12 rounded-xl flex items-center justify-center border border-stone-200 shadow-sm relative overflow-hidden cursor-pointer" data-index="1" data-hd-src={imgFloorplan2HD.src} data-caption="Second Floor: Private Suites & Spa">
                            <Image src={imgFloorplan2} alt="Second Floor Plan" class="w-full h-auto object-contain mix-blend-multiply opacity-80 transition-transform duration-700 ease-out group-hover:scale-105" />
                            
                            <div class="absolute inset-0 bg-white/10 backdrop-blur-[1px] opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center pointer-events-none">
                                <span class="font-sans text-[10px] md:text-xs font-medium tracking-[0.2em] uppercase text-stone-800 border border-stone-800 px-6 py-3 rounded-full bg-white/90 shadow-sm">View Floorplan</span>
                            </div>
                        </button>
                        <span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-stone-400 text-center xl:text-left">
                            Second Floor: Private Suites & Spa
                        </span>
                    </div>

                </div>

            </div>
        </section>

        <section id="gallery" class="px-6 md:px-12 py-16 md:py-24 lg:py-32 max-w-[100rem] mx-auto border-t border-stone-200 relative">
            
            <div class="reveal-el mb-8 md:mb-12 lg:mb-20">
                <span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-stone-400 mb-6 block">The Gallery</span>
            </div>

            <div class="reveal-el grid grid-cols-1 xl:grid-cols-12 gap-4 md:gap-6 xl:gap-12 items-stretch w-full">
                
                <div id="main-gallery-container" class="xl:col-span-7 w-full relative aspect-[4/3] xl:aspect-[3/2] bg-stone-50 overflow-hidden rounded-xl border border-stone-200 shadow-sm">
                    <img id="main-gallery-image" src={img1.src} alt="Gallery Image" class="w-full h-full object-cover xl:absolute xl:inset-0 transition-opacity duration-300 ease-in-out opacity-100 select-none" loading="lazy" decoding="async"/>
                </div>

                <div class="xl:hidden w-full relative carousel-blur overflow-hidden">
                    <div id="mobile-thumb-scroll" class="flex overflow-x-auto snap-x snap-mandatory scrollbar-hide py-2 px-[5vw]">
                        
                        <div class="mobile-set flex gap-2 md:gap-3 pr-2 md:pr-3 shrink-0">
                            {galleryImages.map((img, index) => (
                                <button class={`gallery-thumb mobile-thumb group flex-none w-[28vw] md:w-[22vw] aspect-square bg-stone-50 border border-stone-200 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none ring-0 snap-center ${index === 0 ? 'active' : ''}`} data-index={index} data-src={img.src.src} aria-label={`View ${img.label}`}>
                                    <Image src={img.src} width={300} alt={`Thumbnail ${index + 1}`} class="w-full h-full object-cover pointer-events-none" />
                                </button>
                            ))}
                        </div>

                        <div class="mobile-set middle-set flex gap-2 md:gap-3 pr-2 md:pr-3 shrink-0">
                            {galleryImages.map((img, index) => (
                                <button class={`gallery-thumb mobile-thumb mobile-target group flex-none w-[28vw] md:w-[22vw] aspect-square bg-stone-50 border border-stone-200 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none ring-0 snap-center ${index === 0 ? 'active' : ''}`} data-index={index} data-src={img.src.src} aria-label={`View ${img.label}`}>
                                    <Image src={img.src} width={300} alt={`Thumbnail ${index + 1}`} class="w-full h-full object-cover pointer-events-none" />
                                </button>
                            ))}
                        </div>

                        <div class="mobile-set flex gap-2 md:gap-3 shrink-0">
                            {galleryImages.map((img, index) => (
                                <button class={`gallery-thumb mobile-thumb group flex-none w-[28vw] md:w-[22vw] aspect-square bg-stone-50 border border-stone-200 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none ring-0 snap-center ${index === 0 ? 'active' : ''}`} data-index={index} data-src={img.src.src} aria-label={`View ${img.label}`}>
                                    <Image src={img.src} width={300} alt={`Thumbnail ${index + 1}`} class="w-full h-full object-cover pointer-events-none" />
                                </button>
                            ))}
                        </div>

                    </div>
                </div>

                <div class="hidden xl:grid xl:col-span-5 w-full grid-cols-4 grid-rows-4 gap-3 content-start">
                    {galleryImages.map((img, index) => (
                        <button class={`gallery-thumb desktop-thumb group w-full h-full aspect-auto bg-stone-50 border border-stone-200 rounded-xl overflow-hidden relative cursor-pointer focus:outline-none ring-0 ${index === 0 ? 'active' : ''}`} data-index={index} data-src={img.src.src} aria-label={`View ${img.label}`}>
                            <Image src={img.src} width={300} alt={`Thumbnail ${index + 1}`} class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110 pointer-events-none" />
                        </button>
                    ))}
                </div>

            </div>
        </section>

        <section id="area" class="px-6 py-16 md:py-24 lg:py-32 max-w-4xl mx-auto border-t border-stone-200">
            <div class="reveal-el text-center mb-12 md:mb-16 lg:mb-24">
                <span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-stone-400 mb-6 block">The Area</span>
                <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-light text-stone-800 tracking-wide">Minamigaoka, Karuizawa</h2>
            </div>

            <div class="flex flex-col border-t border-stone-200">
                
                <div class="reveal-el flex flex-col md:flex-row py-6 md:py-8 border-b border-stone-200 gap-2 md:gap-8">
                    <div class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-stone-400 md:w-1/3 pt-1">Address</div>
                    <div class="font-sans text-sm md:text-base lg:text-lg text-stone-800 font-light md:w-2/3 leading-loose flex flex-col gap-1">
                        <span>19-29 Seisatsuba, Oaza Nagakura, Karuizawa-machi, Nagano</span>
                        <span class="text-xs md:text-sm text-stone-500 font-light tracking-wide mt-1">長野県北佐久郡軽井沢町大字長倉字制札場１９－２９</span>
                    </div>
                </div>

                <div class="reveal-el flex flex-col md:flex-row py-6 md:py-8 border-b border-stone-200 gap-2 md:gap-8">
                    <div class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-stone-400 md:w-1/3 pt-1">The Estate</div>
                    <div class="font-sans text-sm md:text-base lg:text-lg text-stone-800 font-light md:w-2/3 leading-loose">
                        An expansive luxury compound sitting on a sprawling 2,981.31 ㎡ (approx. 900 Tsubo) private forest plot[cite: 138, 142, 178].
                    </div>
                </div>

                <div class="reveal-el flex flex-col md:flex-row py-6 md:py-8 border-b border-stone-200 gap-2 md:gap-8">
                    <div class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-stone-400 md:w-1/3 pt-1">Neighborhood</div>
                    <div class="font-sans text-sm md:text-base lg:text-lg text-stone-800 font-light md:w-2/3 leading-loose">
                        Located within the prestigious Minamigaoka Project area[cite: 124, 144]. This enclave offers profound tranquility and seclusion, sitting immediately adjacent to the lush greens of the Karuizawa Golf Club[cite: 117].
                    </div>
                </div>
                
                <div class="reveal-el flex flex-col md:flex-row py-6 md:py-8 border-b border-stone-200 gap-2 md:gap-8">
                    <div class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-stone-400 md:w-1/3 pt-1">Access</div>
                    <div class="font-sans text-sm md:text-base lg:text-lg text-stone-800 font-light md:w-2/3 leading-loose">
                        Conveniently accessed via the National Route 18 Bypass, offering a seamless journey from the Hokuriku Shinkansen and central Tokyo[cite: 53].
                    </div>
                </div>

            </div>
        </section>

        <section id="inquire" class="px-6 py-24 md:py-32 lg:py-48 max-w-3xl mx-auto border-t border-stone-200">
            <div class="reveal-el text-center mb-12 md:mb-16 lg:mb-24">
                <span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-stone-400 mb-6 block">Private Viewing</span>
                <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-light text-stone-800 tracking-wide mb-8">Inquire about this property</h2>
            </div>

            <form class="flex flex-col gap-8 md:gap-12">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
                    <div class="reveal-el flex flex-col gap-2 md:gap-3">
                        <label for="name" class="font-sans text-[10px] md:text-xs font-medium tracking-[0.2em] uppercase text-stone-400">Name</label>
                        <input type="text" id="name" class="w-full bg-transparent border-b border-stone-300 py-2 font-sans text-base md:text-lg font-light focus:outline-none focus:border-stone-800 transition-colors rounded-none" required />
                    </div>
                    <div class="reveal-el flex flex-col gap-2 md:gap-3">
                        <label for="email" class="font-sans text-[10px] md:text-xs font-medium tracking-[0.2em] uppercase text-stone-400">Email</label>
                        <input type="email" id="email" class="w-full bg-transparent border-b border-stone-300 py-2 font-sans text-base md:text-lg font-light focus:outline-none focus:border-stone-800 transition-colors rounded-none" required />
                    </div>
                </div>
                <div class="reveal-el flex flex-col gap-2 md:gap-3">
                    <label for="message" class="font-sans text-[10px] md:text-xs font-medium tracking-[0.2em] uppercase text-stone-400">Message</label>
                    <textarea id="message" rows="4" class="w-full bg-transparent border-b border-stone-300 py-2 font-sans text-base md:text-lg font-light focus:outline-none focus:border-stone-800 transition-colors resize-none rounded-none"></textarea>
                </div>
                <button type="submit" class="reveal-el self-center mt-4 md:mt-8 bg-stone-800 text-white font-sans text-[10px] md:text-xs font-medium tracking-[0.2em] uppercase px-10 md:px-12 py-4 md:py-5 hover:bg-stone-700 transition-colors w-full md:w-auto cursor-pointer">
                    Submit Inquiry
                </button>
            </form>
        </section>

    </main>
    
    <div class="reveal-el">
        <Footer />
    </div>

    <div id="lightbox" class="fixed inset-0 z-50 flex items-center justify-center bg-stone-950/95 opacity-0 pointer-events-none transition-opacity duration-500">
        <button id="lightbox-close" class="absolute top-6 right-6 md:top-12 md:right-12 text-white font-sans text-[10px] md:text-xs font-medium tracking-[0.2em] uppercase p-4 hover:text-stone-400 transition-colors cursor-pointer z-50">
            Close &times;
        </button>

        <button id="lightbox-prev" class="absolute left-4 bottom-8 md:left-8 md:top-1/2 md:-translate-y-1/2 md:bottom-auto text-white font-sans text-[10px] md:text-xs font-medium tracking-[0.2em] uppercase p-4 hover:text-stone-400 transition-colors cursor-pointer z-50">
            &larr; Prev
        </button>
        <button id="lightbox-next" class="absolute right-4 bottom-8 md:right-8 md:top-1/2 md:-translate-y-1/2 md:bottom-auto text-white font-sans text-[10px] md:text-xs font-medium tracking-[0.2em] uppercase p-4 hover:text-stone-400 transition-colors cursor-pointer z-50">
            Next &rarr;
        </button>

        <div class="relative w-full h-full max-w-7xl max-h-[90vh] p-6 md:p-24 flex items-center justify-center">
            <img id="lightbox-image" src="" alt="HD Floorplan" class="max-w-full max-h-[85vh] object-contain opacity-0 transition-opacity duration-300" />
        </div>
        
        <div class="absolute bottom-24 md:bottom-12 left-1/2 -translate-x-1/2 text-stone-400 font-sans text-[10px] tracking-[0.2em] uppercase z-50 w-full text-center px-4">
            <span id="lightbox-caption"></span>
        </div>
    </div>

</Layout>

<style is:global>
    html, body {
        overflow-x: clip;
        width: 100%;
        background-color: #F2EFE9;
    }
</style>

<style>
    @keyframes scrollDrop {
        0% { transform: translateY(-100%); opacity: 0; }
        50% { opacity: 1; }
        100% { transform: translateY(200%); opacity: 0; }
    }
    .animate-scroll-drop {
        animation: scrollDrop 2s cubic-bezier(0.77, 0, 0.175, 1) infinite;
    }

    .gallery-thumb::after {
        content: '';
        position: absolute;
        inset: 0;
        background-color: white;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }
    .gallery-thumb:hover::after {
        opacity: 0.15; 
    }
    .gallery-thumb.active::after {
        opacity: 0.65; 
    }
    .gallery-thumb.active {
        pointer-events: none; 
    }

    /* RE-ENGINEERED SMOOTH BLUR VIGNETTE */
    .carousel-blur::before,
    .carousel-blur::after {
        content: '';
        position: absolute;
        top: -10px;
        bottom: -10px;
        width: 15vw; /* Much wider for a truly soft, natural falloff */
        max-width: 80px;
        pointer-events: none;
        z-index: 10;
        backdrop-filter: blur(4px); /* Softer physical blur to prevent Safari rendering a "box" */
        -webkit-backdrop-filter: blur(4px);
    }
    .carousel-blur::before {
        left: -1px;
        background: linear-gradient(to right, rgba(242, 239, 233, 0.95) 0%, rgba(242, 239, 233, 0) 100%);
        /* Perfect 0-100 gradient mask absolutely prevents the rectangular edge you saw */
        -webkit-mask-image: linear-gradient(to right, black 0%, transparent 100%);
        mask-image: linear-gradient(to right, black 0%, transparent 100%);
    }
    .carousel-blur::after {
        right: -1px;
        background: linear-gradient(to left, rgba(242, 239, 233, 0.95) 0%, rgba(242, 239, 233, 0) 100%);
        -webkit-mask-image: linear-gradient(to left, black 0%, transparent 100%);
        mask-image: linear-gradient(to left, black 0%, transparent 100%);
    }

    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
    .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {

        // ---------------------------------------------------------
        // FLOORPLAN LIGHTBOX ENGINE
        // ---------------------------------------------------------
        const floorplanTriggers = document.querySelectorAll('.floorplan-trigger');
        const lightbox = document.getElementById('lightbox');
        const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement;
        const lightboxClose = document.getElementById('lightbox-close');
        const lightboxPrev = document.getElementById('lightbox-prev');
        const lightboxNext = document.getElementById('lightbox-next');
        const lightboxCaption = document.getElementById('lightbox-caption');

        if (lightbox && lightboxImage && floorplanTriggers.length > 0) {
            
            const floorplanData = Array.from(floorplanTriggers).map(t => ({
                src: t.getAttribute('data-hd-src'),
                caption: t.getAttribute('data-caption')
            }));

            let currentLbIndex = 0;
            let isLbTransitioning = false;

            function updateLightbox(index: number) {
                if (isLbTransitioning) return;
                isLbTransitioning = true;
                currentLbIndex = index;
                
                lightboxImage.classList.remove('opacity-100');
                lightboxImage.classList.add('opacity-0');
                
                setTimeout(() => {
                    if (floorplanData[currentLbIndex].src) {
                        lightboxImage.src = floorplanData[currentLbIndex].src!;
                    }
                    if (lightboxCaption) {
                        lightboxCaption.textContent = floorplanData[currentLbIndex].caption;
                    }
                }, 300); 
            }

            lightboxImage.onload = () => {
                if (lightbox.classList.contains('opacity-100')) {
                    lightboxImage.classList.remove('opacity-0');
                    lightboxImage.classList.add('opacity-100');
                    isLbTransitioning = false;
                }
            };

            floorplanTriggers.forEach((trigger, index) => {
                trigger.addEventListener('click', (e) => {
                    e.preventDefault();
                    currentLbIndex = index;
                    
                    const hdSrc = floorplanData[currentLbIndex].src;
                    if (hdSrc) lightboxImage.src = hdSrc;
                    
                    if (lightboxCaption) {
                        lightboxCaption.textContent = floorplanData[currentLbIndex].caption;
                    }
                    
                    lightbox.classList.remove('pointer-events-none', 'opacity-0');
                    lightbox.classList.add('opacity-100');
                });
            });

            if (lightboxPrev && lightboxNext) {
                lightboxPrev.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const newIndex = (currentLbIndex - 1 + floorplanData.length) % floorplanData.length;
                    updateLightbox(newIndex);
                });

                lightboxNext.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const newIndex = (currentLbIndex + 1) % floorplanData.length;
                    updateLightbox(newIndex);
                });
            }

            const closeLightbox = () => {
                lightbox.classList.remove('opacity-100');
                lightbox.classList.add('opacity-0', 'pointer-events-none');
                lightboxImage.classList.remove('opacity-100');
                lightboxImage.classList.add('opacity-0');
                setTimeout(() => { lightboxImage.src = ''; }, 300);
            };

            if (lightboxClose) lightboxClose.addEventListener('click', closeLightbox);
            lightbox.addEventListener('click', (e) => {
                if (e.target === lightbox) closeLightbox();
            });
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && lightbox.classList.contains('opacity-100')) closeLightbox();
            });
        }


        // ---------------------------------------------------------
        // GALLERY INTERACTIVE ENGINE
        // ---------------------------------------------------------
        const mainImage = document.getElementById('main-gallery-image') as HTMLImageElement;
        const mainContainer = document.getElementById('main-gallery-container');
        const thumbnails = document.querySelectorAll('.gallery-thumb');
        const mobileScroll = document.getElementById('mobile-thumb-scroll');

        if (!mainImage || !mainContainer || thumbnails.length === 0) return;

        let isTransitioning = false;
        let currentIndex = 0;
        const totalImages = 16; 

        const desktopThumbs = document.querySelectorAll('.desktop-thumb');
        const imageList = Array.from(desktopThumbs).map(t => t.getAttribute('data-src'));

        window.addEventListener('load', () => {
            setTimeout(() => {
                imageList.forEach(src => {
                    if (src) {
                        const img = new Image();
                        img.src = src;
                    }
                });
            }, 800);
        });

        let activeMobileThumb: Element | null = null;
        
        function initInfiniteScroll() {
            if (!mobileScroll || window.innerWidth >= 1280) return;
            
            const allMobileThumbs = Array.from(document.querySelectorAll('.mobile-thumb'));
            if (allMobileThumbs.length < 48) return;

            activeMobileThumb = allMobileThumbs[16];
            const setWidth = mobileScroll.scrollWidth / 3;

            if (mobileScroll.scrollLeft === 0) {
                mobileScroll.scrollLeft = setWidth;
            }

            let scrollTimeout;
            mobileScroll.addEventListener('scroll', () => {
                clearTimeout(scrollTimeout);
                scrollTimeout = setTimeout(() => {
                    const currentScroll = mobileScroll.scrollLeft;
                    
                    if (currentScroll < setWidth * 0.5) {
                        mobileScroll.style.scrollSnapType = 'none';
                        mobileScroll.style.scrollBehavior = 'auto'; 
                        mobileScroll.scrollLeft += setWidth;
                        void mobileScroll.offsetWidth; 
                        mobileScroll.style.scrollSnapType = 'x mandatory';
                    } 
                    else if (currentScroll > setWidth * 1.5) {
                        mobileScroll.style.scrollSnapType = 'none';
                        mobileScroll.style.scrollBehavior = 'auto';
                        mobileScroll.scrollLeft -= setWidth;
                        void mobileScroll.offsetWidth; 
                        mobileScroll.style.scrollSnapType = 'x mandatory';
                    }
                }, 150); 
            }, { passive: true });
        }

        setTimeout(initInfiniteScroll, 100);
        window.addEventListener('resize', initInfiniteScroll);


        function updateGallery(clickedThumbElement: Element) {
            if (!clickedThumbElement || isTransitioning || clickedThumbElement.classList.contains('active')) return;
            
            isTransitioning = true;
            const newSrc = clickedThumbElement.getAttribute('data-src');
            const realIndex = parseInt(clickedThumbElement.getAttribute('data-index') || "0", 10);

            mainImage.style.opacity = '0';

            mainImage.addEventListener('transitionend', function handler() {
                mainImage.removeEventListener('transitionend', handler);

                if (newSrc) mainImage.src = newSrc;
                currentIndex = realIndex;

                thumbnails.forEach(t => t.classList.remove('active'));
                const matchingThumbs = document.querySelectorAll(`.gallery-thumb[data-index="${realIndex}"]`);
                matchingThumbs.forEach(t => t.classList.add('active'));

                if (window.innerWidth < 1280 && mobileScroll && activeMobileThumb) {
                    activeMobileThumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
                }

                mainImage.onload = () => {
                    mainImage.style.opacity = '1';
                    isTransitioning = false; 
                };
            }, { once: true });
        }


        thumbnails.forEach(thumb => {
            thumb.addEventListener('click', () => {
                if (thumb.classList.contains('mobile-thumb') || thumb.classList.contains('mobile-target')) {
                    activeMobileThumb = thumb; 
                } else {
                    const realIndex = thumb.getAttribute('data-index');
                    activeMobileThumb = document.querySelector(`.mobile-target[data-index="${realIndex}"]`);
                }
                updateGallery(thumb);
            });
        });


        let touchStartX = 0;
        let touchEndX = 0;

        mainContainer.addEventListener('touchstart', (e: TouchEvent) => {
            touchStartX = e.changedTouches[0].screenX;
        }, { passive: true });

        mainContainer.addEventListener('touchend', (e: TouchEvent) => {
            touchEndX = e.changedTouches[0].screenX;
            handleSwipe();
        }, { passive: true });

        function handleSwipe() {
            if (window.innerWidth >= 1280 || !activeMobileThumb) return; 
            
            const threshold = 40; 
            const allMobileThumbs = Array.from(document.querySelectorAll('.mobile-thumb'));
            const currentIndexInArray = allMobileThumbs.indexOf(activeMobileThumb as Element);
            
            if (touchStartX - touchEndX > threshold) {
                if (currentIndexInArray < allMobileThumbs.length - 1) {
                    activeMobileThumb = allMobileThumbs[currentIndexInArray + 1];
                    updateGallery(activeMobileThumb);
                }
            } else if (touchEndX - touchStartX > threshold) {
                if (currentIndexInArray > 0) {
                    activeMobileThumb = allMobileThumbs[currentIndexInArray - 1];
                    updateGallery(activeMobileThumb);
                }
            }
        }
    });
</script>