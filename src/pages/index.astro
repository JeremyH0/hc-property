---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="HC Property | Exclusive Residence">
	<Navigation />
	
	<main class="w-full tracking-normal leading-loose pt-20 md:pt-24">
		
		<section class="relative w-full px-6 md:px-12 py-16 md:py-24 max-w-[100rem] mx-auto flex flex-col gap-12 md:gap-16">
			<div class="flex flex-col items-center text-center max-w-4xl mx-auto mt-8 md:mt-12">
				<span class="hero-reveal font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 mb-6 block">
					Kutchan, Hokkaido
				</span>
				<h1 class="hero-reveal font-serif text-5xl md:text-7xl lg:text-8xl font-light text-zinc-800 tracking-tight leading-none mb-8">
					A sanctuary of minimalist purity.
				</h1>
				<p class="hero-reveal font-sans text-base md:text-lg text-zinc-500 max-w-2xl font-light leading-loose">
					Discover an exclusive retreat designed to blend seamlessly with the alpine landscapes of Japan. A masterclass in space, light, and silence.
				</p>
			</div>
			<div class="hero-reveal w-full aspect-video lg:aspect-[21/9] bg-zinc-100 overflow-hidden rounded-xl">
				<img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?ixlib=rb-4.0.3&auto=format&fit=crop&w=2500&q=80" alt="Exterior view of the luxury property" class="w-full h-full object-cover" loading="eager" decoding="async"/>
			</div>
		</section>

		<section id="concept" class="px-6 py-32 md:py-48 max-w-4xl mx-auto text-center">
			<span class="reveal-el font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 mb-8 block">The Concept</span>
			<h2 class="reveal-el font-serif text-4xl md:text-6xl font-light text-zinc-800 tracking-wide mb-16 leading-tight">
				A seamless dialogue <br class="hidden md:block"/> between nature and architecture.
			</h2>
			<div class="reveal-el font-sans text-zinc-500 font-light leading-loose flex flex-col gap-8 text-left md:text-center text-base md:text-lg max-w-3xl mx-auto">
				<p>Inspired by the serenity of Kutchan's ancient forests, this residence is designed as an instrument for experiencing nature. The architecture does not impose upon the landscape; rather, it frames it, allowing the shifting seasons to become the primary artwork of the home.</p>
				<p>By stripping away the superfluous, we create a space where time slows down. A return to the essential, where light, texture, and silence elevate the everyday into something profound.</p>
			</div>
		</section>

		<section id="architecture" class="px-6 md:px-12 py-24 md:py-32 max-w-[100rem] mx-auto">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-24 items-center">
				<div class="reveal-el flex flex-col gap-6 lg:px-8">
					<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400">Architecture</span>
					<h3 class="font-serif text-3xl md:text-4xl font-light text-zinc-800">Unobstructed Views</h3>
					<p class="font-sans text-base text-zinc-500 font-light leading-loose">Floor-to-ceiling triple-glazed glass spans the entire living area, framing the dramatic silhouettes of Mount Yotei. The architecture ensures you are always connected to the changing light.</p>
				</div>
				<div class="reveal-el w-full aspect-[4/3] bg-zinc-100 overflow-hidden rounded-xl">
					<img src="https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?ixlib=rb-4.0.3&auto=format&fit=crop&w=1600&q=80" alt="Interior living space" class="w-full h-full object-cover" loading="lazy" decoding="async"/>
				</div>

				<div class="reveal-el w-full aspect-[4/3] bg-zinc-100 overflow-hidden md:order-last rounded-xl">
					<img src="https://images.unsplash.com/photo-1449844908441-8829872d2607?ixlib=rb-4.0.3&auto=format&fit=crop&w=1600&q=80" alt="Architectural detail" class="w-full h-full object-cover" loading="lazy" decoding="async"/>
				</div>
				<div class="reveal-el flex flex-col gap-6 lg:px-8 md:order-first">
					<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400">Materials</span>
					<h3 class="font-serif text-3xl md:text-4xl font-light text-zinc-800">Raw & Refined</h3>
					<p class="font-sans text-base text-zinc-500 font-light leading-loose">A curated palette of locally sourced volcanic stone and weathered cedar. Materials chosen for their longevity and their ability to age with grace alongside the Hokkaido seasons.</p>
				</div>
			</div>
		</section>

		<!-- MASTER & THUMBNAIL GALLERY -->
		<section id="gallery" class="px-6 md:px-12 py-24 md:py-32 max-w-[100rem] mx-auto border-t border-zinc-100">
			
			<div class="reveal-el mb-10 md:mb-16">
				<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 mb-6 block">The Gallery</span>
				<h2 class="font-serif text-3xl md:text-5xl font-light text-zinc-800 tracking-wide">A visual exploration.</h2>
			</div>

			<div class="reveal-el flex flex-col lg:flex-row gap-3 md:gap-4 lg:gap-6 w-full">
				
				<!-- 1. Master Viewer -->
				<div class="w-full lg:w-[65%] relative aspect-[4/3] md:aspect-[16/10] bg-zinc-100 overflow-hidden rounded-xl shadow-sm">
					<img id="main-gallery-image" src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?ixlib=rb-4.0.3&auto=format&fit=crop&w=2500&q=80" alt="The Exterior" class="w-full h-full object-cover transition-opacity duration-500 ease-in-out opacity-100" loading="lazy" decoding="async"/>
					
					<div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-black/60 to-transparent pointer-events-none z-20 rounded-b-xl"></div>
					<span id="main-gallery-caption" class="absolute bottom-6 left-6 md:bottom-8 md:left-8 font-sans text-xs tracking-[0.2em] uppercase text-white pointer-events-none drop-shadow-md z-20">
						The Exterior
					</span>
				</div>

				<!-- 2. The Thumbnails -->
				<div class="w-full lg:w-[35%] grid grid-cols-4 gap-2 md:gap-3 lg:gap-4 content-start">
					<button class="gallery-thumb active w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300" data-src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?ixlib=rb-4.0.3&auto=format&fit=crop&w=2500&q=80" data-caption="The Exterior" aria-label="View The Exterior">
						<img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="The Exterior" class="w-full h-full object-cover pointer-events-none" loading="lazy" decoding="async"/>
					</button>

					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300" data-src="https://images.unsplash.com/photo-1600607687920-4e2a09cf159d?ixlib=rb-4.0.3&auto=format&fit=crop&w=2500&q=80" data-caption="Living Space" aria-label="View Living Space">
						<img src="https://images.unsplash.com/photo-1600607687920-4e2a09cf159d?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Living Space" class="w-full h-full object-cover pointer-events-none" loading="lazy" decoding="async"/>
					</button>

					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300" data-src="https://unsplash.com/photos/5a0JBpFl22U/download?w=2500" data-caption="The Kitchen" aria-label="View The Kitchen">
						<img src="https://unsplash.com/photos/5a0JBpFl22U/download?w=600" alt="The Kitchen" class="w-full h-full object-cover pointer-events-none" loading="lazy" decoding="async"/>
					</button>

					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300" data-src="https://images.unsplash.com/photo-1600607686527-6fb886090705?ixlib=rb-4.0.3&auto=format&fit=crop&w=2500&q=80" data-caption="Formal Dining" aria-label="View Formal Dining">
						<img src="https://images.unsplash.com/photo-1600607686527-6fb886090705?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Formal Dining" class="w-full h-full object-cover pointer-events-none" loading="lazy" decoding="async"/>
					</button>

					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300" data-src="https://images.unsplash.com/photo-1616594039964-ae9021a400a0?ixlib=rb-4.0.3&auto=format&fit=crop&w=2500&q=80" data-caption="Master Suite" aria-label="View Master Suite">
						<img src="https://images.unsplash.com/photo-1616594039964-ae9021a400a0?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Master Suite" class="w-full h-full object-cover pointer-events-none" loading="lazy" decoding="async"/>
					</button>

					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300" data-src="https://images.unsplash.com/photo-1600566752355-35792bedcfea?ixlib=rb-4.0.3&auto=format&fit=crop&w=2500&q=80" data-caption="Master Bath" aria-label="View Master Bath">
						<img src="https://images.unsplash.com/photo-1600566752355-35792bedcfea?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Master Bath" class="w-full h-full object-cover pointer-events-none" loading="lazy" decoding="async"/>
					</button>

					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300" data-src="https://images.unsplash.com/photo-1584622650111-993a426fbf0a?ixlib=rb-4.0.3&auto=format&fit=crop&w=2500&q=80" data-caption="Private Onsen" aria-label="View Private Onsen">
						<img src="https://images.unsplash.com/photo-1584622650111-993a426fbf0a?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Private Onsen" class="w-full h-full object-cover pointer-events-none" loading="lazy" decoding="async"/>
					</button>

					<button class="gallery-thumb w-full aspect-square bg-zinc-100 rounded-lg md:rounded-xl overflow-hidden relative cursor-pointer focus:outline-none transition-all duration-300" data-src="https://images.unsplash.com/photo-1510798831971-661eb04b3739?ixlib=rb-4.0.3&auto=format&fit=crop&w=2500&q=80" data-caption="Winter Architecture" aria-label="View Winter Architecture">
						<img src="https://images.unsplash.com/photo-1510798831971-661eb04b3739?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Winter Architecture" class="w-full h-full object-cover pointer-events-none" loading="lazy" decoding="async"/>
					</button>

				</div>
			</div>
		</section>

		<section id="area" class="px-6 py-24 md:py-32 max-w-4xl mx-auto border-t border-zinc-100">
			<div class="reveal-el text-center mb-16 md:mb-24">
				<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 mb-6 block">The Area</span>
				<h2 class="font-serif text-3xl md:text-5xl font-light text-zinc-800 tracking-wide">Kutchan & Niseko</h2>
			</div>

			<div class="flex flex-col border-t border-zinc-100">
				<div class="reveal-el flex flex-col md:flex-row py-6 md:py-8 border-b border-zinc-100 gap-2 md:gap-8">
					<div class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 md:w-1/3 pt-1">Location</div>
					<div class="font-sans text-base md:text-lg text-zinc-800 font-light md:w-2/3 leading-loose">Kutchan, Hokkaido, Japan</div>
				</div>
				<div class="reveal-el flex flex-col md:flex-row py-6 md:py-8 border-b border-zinc-100 gap-2 md:gap-8">
					<div class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 md:w-1/3 pt-1">Winter Access</div>
					<div class="font-sans text-base md:text-lg text-zinc-800 font-light md:w-2/3 leading-loose">Minutes from the world-class powder snow of Grand Hirafu and Niseko Hanazono resorts.</div>
				</div>
				<div class="reveal-el flex flex-col md:flex-row py-6 md:py-8 border-b border-zinc-100 gap-2 md:gap-8">
					<div class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 md:w-1/3 pt-1">Surroundings</div>
					<div class="font-sans text-base md:text-lg text-zinc-800 font-light md:w-2/3 leading-loose">Immersed in serene alpine forests with commanding views of Mount Yotei.</div>
				</div>
			</div>
		</section>

		<section id="inquire" class="px-6 py-32 md:py-48 max-w-3xl mx-auto border-t border-zinc-100">
			<div class="reveal-el text-center mb-16 md:mb-24">
				<span class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 mb-6 block">Private Viewing</span>
				<h2 class="font-serif text-3xl md:text-5xl font-light text-zinc-800 tracking-wide mb-8">Inquire about this property</h2>
			</div>

			<form class="flex flex-col gap-12">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-12">
					<div class="reveal-el flex flex-col gap-3">
						<label for="name" class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400">Name</label>
						<input type="text" id="name" class="w-full bg-transparent border-b border-zinc-200 py-2 font-sans text-lg font-light focus:outline-none focus:border-zinc-800 transition-colors rounded-none" required />
					</div>
					<div class="reveal-el flex flex-col gap-3">
						<label for="email" class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400">Email</label>
						<input type="email" id="email" class="w-full bg-transparent border-b border-zinc-200 py-2 font-sans text-lg font-light focus:outline-none focus:border-zinc-800 transition-colors rounded-none" required />
					</div>
				</div>
				<div class="reveal-el flex flex-col gap-3">
					<label for="message" class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400">Message</label>
					<textarea id="message" rows="4" class="w-full bg-transparent border-b border-zinc-200 py-2 font-sans text-lg font-light focus:outline-none focus:border-zinc-800 transition-colors resize-none rounded-none"></textarea>
				</div>
				<button type="submit" class="reveal-el self-center mt-8 bg-zinc-800 text-white font-sans text-xs font-medium tracking-[0.2em] uppercase px-12 py-5 hover:bg-zinc-700 transition-colors w-full md:w-auto cursor-pointer">
					Submit Inquiry
				</button>
			</form>
		</section>

	</main>
	
	<div class="reveal-el">
		<Footer />
	</div>
</Layout>

<style>
	.gallery-thumb {
		opacity: 0.4;
		transition: opacity 0.4s ease;
	}
	.gallery-thumb:hover {
		opacity: 0.7;
	}
	.gallery-thumb.active {
		opacity: 1;
	}
</style>

<script>
	// --- PRO EVENT-DRIVEN CROSSFADE ENGINE ---
	document.addEventListener('DOMContentLoaded', () => {
		const mainImage = document.getElementById('main-gallery-image') as HTMLImageElement;
		const mainCaption = document.getElementById('main-gallery-caption');
		const thumbnails = document.querySelectorAll('.gallery-thumb');

		if (!mainImage || thumbnails.length === 0) return;

		let isTransitioning = false;

		thumbnails.forEach(thumb => {
			thumb.addEventListener('click', () => {
				// If clicked on active, or already transitioning, ignore to prevent glitching
				if (isTransitioning || thumb.classList.contains('active')) return;
				
				const newSrc = thumb.getAttribute('data-src');
				const newCaption = thumb.getAttribute('data-caption');
				if (!newSrc) return;

				isTransitioning = true;

				// 1. Fade out the main image
				mainImage.style.opacity = '0';

				// 2. Wait for the CSS transition to complete (Event-driven)
				mainImage.addEventListener('transitionend', function handler() {
					mainImage.removeEventListener('transitionend', handler);

					// 3. Swap the source
					mainImage.src = newSrc;
					mainImage.alt = newCaption || 'Gallery Image';
					if (mainCaption) mainCaption.innerHTML = newCaption || '';

					// 4. Update thumbnails state
					thumbnails.forEach(t => t.classList.remove('active'));
					thumb.classList.add('active');

					// 5. Fade back in once the new image is ready
					mainImage.onload = () => {
						mainImage.style.opacity = '1';
						isTransitioning = false; // Ready for next click
					};
				}, { once: true });
			});
		});
	});
</script>