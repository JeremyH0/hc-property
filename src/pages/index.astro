<!-- SCRIPTS                                    -->
<!-- ========================================== -->
<script>
    document.addEventListener('DOMContentLoaded', () => {
        
        // ---------------------------------------------------------
        // 1. UNIFIED LIGHTBOX ENGINE (Floorplans, Gallery, Carousels)
        // ---------------------------------------------------------
        const floorplanTriggers = document.querySelectorAll('.floorplan-trigger');
        const lightbox = document.getElementById('lightbox');
        const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement;
        const lightboxClose = document.getElementById('lightbox-close');
        const lightboxPrev = document.getElementById('lightbox-prev');
        const lightboxNext = document.getElementById('lightbox-next');
        const lightboxCaption = document.getElementById('lightbox-caption');
        const lightboxCaptionContainer = document.getElementById('lightbox-caption-container');

        if (lightbox && lightboxImage) {
            
            const floorplanData = Array.from(floorplanTriggers).map(t => ({
                src: t.getAttribute('data-hd-src'),
                caption: t.getAttribute('data-caption')
            }));

            let currentLightboxData: {src: string | null, caption: string | null}[] = [];
            let currentLbIndex = 0;
            let isLbTransitioning = false;
            let currentLbSource: string | null = null; // Tracks who opened the lightbox

            let scale = 1, panX = 0, panY = 0, isPanning = false, startX = 0, startY = 0;
            let lastTapTime = 0, initialPinchDistance: number | null = null, initialScale = 1;
            let isDoubleTap = false; // Prevents swipe trigger after double tap zoom out

            const updateTransform = (smooth = false) => {
                lightboxImage.style.transition = smooth ? 'opacity 0.3s ease, transform 0.3s ease-out' : 'opacity 0.3s ease';
                lightboxImage.style.transform = `translate(${panX}px, ${panY}px) scale(${scale})`;
                lightboxImage.style.cursor = scale > 1 ? (isPanning ? 'grabbing' : 'grab') : 'default';
            };

            const getDistance = (touches: TouchList) => {
                return Math.hypot(
                    touches[0].clientX - touches[1].clientX,
                    touches[0].clientY - touches[1].clientY
                );
            };

            lightbox.addEventListener('wheel', (e) => {
                if (!lightbox.classList.contains('opacity-100')) return;
                e.preventDefault();
                
                scale += e.deltaY < 0 ? 0.15 : -0.15;
                scale = Math.max(1, Math.min(scale, 4));
                if (scale === 1) { panX = 0; panY = 0; }
                
                updateTransform();
            }, { passive: false });

            lightboxImage.addEventListener('dblclick', (e) => {
                e.preventDefault();
                if (scale > 1) { scale = 1; panX = 0; panY = 0; } 
                else { scale = 2.5; }
                updateTransform(true);
            });

            lightboxImage.addEventListener('mousedown', (e) => {
                if (scale === 1) return;
                e.preventDefault(); 
                isPanning = true;
                startX = e.clientX - panX;
                startY = e.clientY - panY;
                updateTransform();
            });

            window.addEventListener('mousemove', (e) => {
                if (!isPanning) return;
                panX = e.clientX - startX;
                panY = e.clientY - startY;
                updateTransform();
            });

            window.addEventListener('mouseup', () => { isPanning = false; updateTransform(); });
            window.addEventListener('mouseleave', () => { isPanning = false; updateTransform(); });

            lightboxImage.addEventListener('touchstart', (e) => {
                if (e.touches.length === 1) {
                    const currentTime = new Date().getTime();
                    const tapLength = currentTime - lastTapTime;
                    
                    if (tapLength < 300 && tapLength > 0) {
                        // Double tap to zoom
                        e.preventDefault();
                        isDoubleTap = true;
                        
                        if (scale > 1) { scale = 1; panX = 0; panY = 0; } 
                        else { scale = 2.5; }
                        updateTransform(true);
                    } else {
                        isDoubleTap = false;
                        // Single touch down
                        if (scale > 1) {
                            isPanning = true;
                            startX = e.touches[0].clientX - panX;
                            startY = e.touches[0].clientY - panY;
                        } else {
                            // Touch start for swiping
                            startX = e.touches[0].clientX;
                        }
                    }
                    lastTapTime = currentTime;
                } else if (e.touches.length === 2) {
                    e.preventDefault();
                    isPanning = false;
                    initialPinchDistance = getDistance(e.touches);
                    initialScale = scale;
                }
            }, { passive: false });

            lightboxImage.addEventListener('touchmove', (e) => {
                if (e.touches.length === 1 && isPanning) {
                    e.preventDefault();
                    panX = e.touches[0].clientX - startX;
                    panY = e.touches[0].clientY - startY;
                    updateTransform();
                } else if (e.touches.length === 2 && initialPinchDistance) {
                    e.preventDefault();
                    const currentDistance = getDistance(e.touches);
                    const pinchRatio = currentDistance / initialPinchDistance;
                    scale = Math.max(1, Math.min(initialScale * pinchRatio, 4));
                    if (scale === 1) { panX = 0; panY = 0; }
                    updateTransform();
                }
            }, { passive: false });

            lightboxImage.addEventListener('touchend', (e) => {
                isPanning = false;
                initialPinchDistance = null;

                // Fullscreen Swipe Logic (Adding !isDoubleTap check here!)
                if (scale === 1 && e.changedTouches.length === 1 && !isDoubleTap) {
                    const endX = e.changedTouches[0].clientX;
                    const diffX = startX - endX;
                    const swipeThreshold = 50;

                    if (diffX > swipeThreshold && currentLightboxData.length > 1) {
                        // Swiped Left -> Next Image
                        updateLightbox((currentLbIndex + 1) % currentLightboxData.length);
                    } else if (diffX < -swipeThreshold && currentLightboxData.length > 1) {
                        // Swiped Right -> Prev Image
                        updateLightbox((currentLbIndex - 1 + currentLightboxData.length) % currentLightboxData.length);
                    }
                }
            });

            function updateLightbox(index: number) {
                if (isLbTransitioning || currentLightboxData.length === 0) return;
                isLbTransitioning = true;
                currentLbIndex = index;

                // Broadcast the change so background carousels/galleries can sync
                if (currentLbSource) {
                    window.dispatchEvent(new CustomEvent('lightbox-image-changed', {
                        detail: {
                            source: currentLbSource,
                            index: currentLbIndex
                        }
                    }));
                }
                
                lightboxImage.classList.remove('opacity-100');
                lightboxImage.classList.add('opacity-0');
                
                setTimeout(() => {
                    scale = 1; panX = 0; panY = 0; updateTransform(true);
                    
                    const data = currentLightboxData[currentLbIndex];
                    if (data.src) lightboxImage.src = data.src;
                    
                    if (lightboxCaption && lightboxCaptionContainer) {
                        if (data.caption) {
                            lightboxCaption.textContent = data.caption;
                            lightboxCaptionContainer.style.display = 'flex';
                        } else {
                            lightboxCaption.textContent = '';
                            lightboxCaptionContainer.style.display = 'none';
                        }
                    }
                }, 300); 
            }

            lightboxImage.onload = () => {
                if (lightbox.classList.contains('opacity-100')) {
                    lightboxImage.classList.remove('opacity-0');
                    lightboxImage.classList.add('opacity-100');
                    isLbTransitioning = false;
                }
            };

            // Floorplan Triggers
            if (floorplanTriggers.length > 0) {
                floorplanTriggers.forEach((trigger, index) => {
                    trigger.addEventListener('click', (e) => {
                        e.preventDefault();
                        currentLightboxData = floorplanData;
                        currentLbIndex = index;
                        currentLbSource = 'floorplans';
                        
                        scale = 1; panX = 0; panY = 0; updateTransform(true);
                        
                        const data = currentLightboxData[currentLbIndex];
                        if (data.src) lightboxImage.src = data.src;
                        
                        if (lightboxCaption && lightboxCaptionContainer) {
                            if (data.caption) {
                                lightboxCaption.textContent = data.caption;
                                lightboxCaptionContainer.style.display = 'flex';
                            } else {
                                lightboxCaptionContainer.style.display = 'none';
                            }
                        }

                        if (lightboxPrev) lightboxPrev.style.display = '';
                        if (lightboxNext) lightboxNext.style.display = '';
                        
                        lightbox.classList.remove('pointer-events-none', 'opacity-0');
                        lightbox.classList.add('opacity-100');
                        document.body.style.overflow = 'hidden';
                        if (window['lenis']) window['lenis'].stop();
                    });
                });
            }

            // Navigation Buttons
            if (lightboxPrev && lightboxNext) {
                lightboxPrev.addEventListener('click', (e) => {
                    e.stopPropagation();
                    if (currentLightboxData.length > 0) {
                        updateLightbox((currentLbIndex - 1 + currentLightboxData.length) % currentLightboxData.length);
                    }
                });
                lightboxNext.addEventListener('click', (e) => {
                    e.stopPropagation();
                    if (currentLightboxData.length > 0) {
                        updateLightbox((currentLbIndex + 1) % currentLightboxData.length);
                    }
                });
            }

            const closeLightbox = () => {
                lightbox.classList.remove('opacity-100');
                lightbox.classList.add('opacity-0', 'pointer-events-none');
                lightboxImage.classList.remove('opacity-100');
                lightboxImage.classList.add('opacity-0');
                
                setTimeout(() => { 
                    lightboxImage.src = ''; 
                    scale = 1; panX = 0; panY = 0; updateTransform(true);
                    currentLbSource = null;
                    
                    if (lightboxPrev) lightboxPrev.style.display = '';
                    if (lightboxNext) lightboxNext.style.display = '';
                    if (lightboxCaptionContainer) lightboxCaptionContainer.style.display = 'flex';
                    document.body.style.overflow = '';
                    if (window['lenis']) window['lenis'].start();
                }, 300);
            };

            if (lightboxClose) lightboxClose.addEventListener('click', closeLightbox);

            // --- Custom Events ---
            // Catch the Carousel Lightbox Event (used by Carousels AND the Main Gallery)
            window.addEventListener('open-carousel-lightbox', (e: any) => {
                currentLightboxData = e.detail.images.map((src: string) => ({ src, caption: '' }));
                currentLbIndex = e.detail.currentIndex || 0;
                currentLbSource = e.detail.source || null;

                scale = 1; panX = 0; panY = 0; updateTransform(true);
                lightboxImage.src = currentLightboxData[currentLbIndex].src!;
                
                if (lightboxCaptionContainer) lightboxCaptionContainer.style.display = 'none';
                
                if (currentLightboxData.length > 1) {
                    if (lightboxPrev) lightboxPrev.style.display = '';
                    if (lightboxNext) lightboxNext.style.display = '';
                } else {
                    if (lightboxPrev) lightboxPrev.style.display = 'none';
                    if (lightboxNext) lightboxNext.style.display = 'none';
                }
                
                lightbox.classList.remove('pointer-events-none', 'opacity-0');
                lightbox.classList.add('opacity-100');
                document.body.style.overflow = 'hidden';
                if (window['lenis']) window['lenis'].stop();
            });

            // Smart click-outside-to-close logic
            lightbox.addEventListener('click', (e) => {
                if (scale > 1) return;
                if (e.target === lightboxImage || e.target === lightboxPrev || e.target === lightboxNext) return;
                closeLightbox();
            });

            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && lightbox.classList.contains('opacity-100')) closeLightbox();
                if (e.key === 'ArrowRight' && lightbox.classList.contains('opacity-100') && currentLightboxData.length > 1) {
                    updateLightbox((currentLbIndex + 1) % currentLightboxData.length);
                }
                if (e.key === 'ArrowLeft' && lightbox.classList.contains('opacity-100') && currentLightboxData.length > 1) {
                    updateLightbox((currentLbIndex - 1 + currentLightboxData.length) % currentLightboxData.length);
                }
            });
        }

        // ---------------------------------------------------------
        // 2. MAIN GALLERY INTERACTIVE ENGINE
        // ---------------------------------------------------------
        const mainImage = document.getElementById('main-gallery-image') as HTMLImageElement;
        const mainContainer = document.getElementById('main-gallery-container');
        const thumbnails = document.querySelectorAll('.gallery-thumb');
        const mobileScroll = document.getElementById('mobile-thumb-scroll');
        const swipeIndicator = document.getElementById('swipe-indicator');
        const gallerySourceId = 'main-gallery-sync'; // ID for syncing with lightbox

        if (!mainImage || !mainContainer || thumbnails.length === 0) return;

        let isTransitioning = false;
        let currentIndex = 0;

        const desktopThumbs = document.querySelectorAll('.desktop-thumb');
        const imageList = Array.from(desktopThumbs).map(t => t.getAttribute('data-src'));

        // Preload images silently in background
        window.addEventListener('load', () => {
            setTimeout(() => {
                imageList.forEach(src => {
                    if (src) {
                        const img = new Image();
                        img.src = src;
                    }
                });
            }, 800);
        });

        let activeMobileThumb: Element | null = document.querySelector('.mobile-thumb[data-index="0"]');

        function updateGallery(clickedThumbElement: Element) {
            if (!clickedThumbElement || isTransitioning || clickedThumbElement.classList.contains('active')) return;
            
            isTransitioning = true;
            
            if (swipeIndicator && !swipeIndicator.classList.contains('opacity-0')) {
                swipeIndicator.classList.add('opacity-0');
            }

            const newSrc = clickedThumbElement.getAttribute('data-src');
            const realIndex = parseInt(clickedThumbElement.getAttribute('data-index') || "0", 10);

            mainImage.style.opacity = '0';

            setTimeout(() => {
                if (newSrc) mainImage.src = newSrc;
                currentIndex = realIndex;

                thumbnails.forEach(t => t.classList.remove('active'));
                const matchingThumbs = document.querySelectorAll(`.gallery-thumb[data-index="${realIndex}"]`);
                matchingThumbs.forEach(t => t.classList.add('active'));

                if (window.innerWidth < 1280 && mobileScroll && activeMobileThumb) {
                    activeMobileThumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
                }

                mainImage.onload = () => {
                    mainImage.style.opacity = '1';
                    isTransitioning = false; 
                };

                if(mainImage.complete) { 
                    mainImage.style.opacity = '1'; 
                    isTransitioning = false; 
                }

            }, 300); 
        }

        thumbnails.forEach(thumb => {
            thumb.addEventListener('click', () => {
                if (thumb.classList.contains('mobile-thumb')) {
                    activeMobileThumb = thumb; 
                } else {
                    const realIndex = thumb.getAttribute('data-index');
                    activeMobileThumb = document.querySelector(`.mobile-thumb[data-index="${realIndex}"]`);
                }
                updateGallery(thumb);
            });
        });

        let touchStartX = 0;
        let touchEndX = 0;

        mainContainer.addEventListener('touchstart', (e: TouchEvent) => {
            touchStartX = e.changedTouches[0].screenX;
        }, { passive: true });
        
        mainContainer.addEventListener('touchend', (e: TouchEvent) => {
            touchEndX = e.changedTouches[0].screenX;
            handleSwipe();
        }, { passive: true });

        // Add tap/click-to-fullscreen for the main gallery image
        mainContainer.addEventListener('click', () => {
            // Ignore clicks if we are currently animating a fade
            if (isTransitioning) return;
            
            // Ignore clicks if the user just swiped (prevents accidental opening)
            if (Math.abs(touchStartX - touchEndX) > 10) {
                touchStartX = 0; touchEndX = 0; // reset
                return; 
            }

            // Trigger the unified lightbox using the carousel event so we can swipe through the whole array!
            if (mainImage.src) {
                window.dispatchEvent(new CustomEvent('open-carousel-lightbox', { 
                    detail: { 
                        images: imageList,
                        currentIndex: currentIndex,
                        source: gallerySourceId // Attach the ID so the lightbox can talk back
                    } 
                }));
            }
        });

        function handleSwipe() {
            if (window.innerWidth >= 1280 || !activeMobileThumb) return;             
            const threshold = 40; 
            const allMobileThumbs = Array.from(document.querySelectorAll('.mobile-thumb'));
            const currentIndexInArray = allMobileThumbs.indexOf(activeMobileThumb as Element);
            
            if (touchStartX - touchEndX > threshold) {
                const nextIndex = (currentIndexInArray + 1) % allMobileThumbs.length;
                activeMobileThumb = allMobileThumbs[nextIndex];
                updateGallery(activeMobileThumb);
            } else if (touchEndX - touchStartX > threshold) {
                const prevIndex = (currentIndexInArray - 1 + allMobileThumbs.length) % allMobileThumbs.length;
                activeMobileThumb = allMobileThumbs[prevIndex];
                updateGallery(activeMobileThumb);
            }
        }

        // Listen for Lightbox changes to sync the background gallery
        window.addEventListener('lightbox-image-changed', (e: any) => {
            if (e.detail.source === gallerySourceId) {
                const targetIndex = e.detail.index;
                const targetThumb = document.querySelector(`.desktop-thumb[data-index="${targetIndex}"]`);
                if (targetThumb) {
                    activeMobileThumb = document.querySelector(`.mobile-thumb[data-index="${targetIndex}"]`);
                    updateGallery(targetThumb);
                }
            }
        });

    // ---------------------------------------------------------
        // 3. INQUIRY FORM HANDLER (UI STATE)
        // ---------------------------------------------------------
        const inquiryForm = document.getElementById('inquiry-form');
        const formContainer = document.getElementById('form-container');
        const successMessage = document.getElementById('success-message');
        const submitBtn = document.getElementById('submit-btn');
        const submitText = document.getElementById('submit-text');

        if (inquiryForm && formContainer && successMessage && submitBtn && submitText) {
            inquiryForm.addEventListener('submit', (e) => {
                e.preventDefault(); // Prevent page reload

                // 1. Update UI to "Sending" state
                submitBtn.disabled = true;
                submitText.textContent = 'Sending...';

                // 2. Simulate a network request delay (e.g., 1.5 seconds)
                // Once you have a backend, you will replace this setTimeout with your actual fetch/axios call.
                setTimeout(() => {
                    
                    // 3. Fade out the form container
                    formContainer.classList.remove('opacity-100');
                    formContainer.classList.add('opacity-0');

                    // 4. Wait for the fade-out to finish, then swap visibility and fade in the success message
                    setTimeout(() => {
                        formContainer.classList.add('hidden');
                        
                        successMessage.classList.remove('hidden');
                        successMessage.classList.add('flex');
                        
                        // Force a tiny delay so the browser registers the display change before fading in
                        setTimeout(() => {
                            successMessage.classList.remove('opacity-0');
                            successMessage.classList.add('opacity-100');
                        }, 50);
                    }, 500); // This 500ms matches the transition-opacity duration on the form container
                }, 1500);
            });
        }
        
    });
</script>