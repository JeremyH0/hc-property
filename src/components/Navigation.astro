---
// Navigation.astro - Minimalist Transparent Header with Smart Lang Logic
---

<header id="main-header" class="w-full fixed top-0 left-0 z-50 transition-all duration-300 bg-transparent border-none">
  <div class="max-w-[100rem] mx-auto px-6 md:px-12 h-20 md:h-24 flex items-center justify-between">
    
    <a href="#" id="header-logo" class="font-sans text-xs md:text-sm font-semibold tracking-[0.2em] uppercase text-white transition-colors duration-300 hover:opacity-70 relative z-50">
      HC Property
    </a>

    <div class="flex items-center gap-6 xl:gap-10">
      
      <nav class="hidden xl:flex items-center gap-10 xl:gap-12" id="desktop-nav">
        <a href="#concept"      class="nav-link font-sans text-xs font-medium tracking-[0.2em] uppercase text-white/90 hover:text-white transition-colors duration-300">Concept</a>
        <a href="#floorplan"    class="nav-link font-sans text-xs font-medium tracking-[0.2em] uppercase text-white/90 hover:text-white transition-colors duration-300">Masterplan</a>
        <a href="#gallery"      class="nav-link font-sans text-xs font-medium tracking-[0.2em] uppercase text-white/90 hover:text-white transition-colors duration-300">Gallery</a>
        <a href="#area"         class="nav-link font-sans text-xs font-medium tracking-[0.2em] uppercase text-white/90 hover:text-white transition-colors duration-300">Area</a>
        <a href="#inquire"      class="nav-link font-sans text-xs font-medium tracking-[0.2em] uppercase text-white/90 hover:text-white transition-colors duration-300">Inquire</a>
      </nav>

      <div id="lang-menu" class="hidden xl:block relative group z-50 font-sans text-[10px] md:text-xs tracking-[0.2em] transition-colors duration-300 text-white">
        <button class="flex items-center gap-1.5 hover:opacity-70 transition-opacity focus:outline-none uppercase py-4" aria-haspopup="true">
          <span id="current-lang-display">EN</span>
          <svg class="w-3 h-3 opacity-50 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
        
        <div class="absolute right-0 top-full w-32 pt-2 opacity-0 pointer-events-none translate-y-2 group-hover:opacity-100 group-hover:pointer-events-auto group-hover:translate-y-0 transition-all duration-300">
          <div class="w-full py-2 bg-[#F2EFE9]/95 backdrop-blur-md border border-stone-200/50 shadow-sm flex flex-col text-left rounded-lg">
            <a href="/" class="block px-5 py-3 text-[10px] tracking-[0.2em] uppercase text-stone-500 hover:text-stone-800 transition-colors">English</a>
            <a href="#" class="block px-5 py-3 text-[10px] tracking-[0.2em] uppercase text-stone-400 hover:text-stone-800 transition-colors">日本語</a>
            <a href="#" class="block px-5 py-3 text-[10px] tracking-[0.2em] uppercase text-stone-400 hover:text-stone-800 transition-colors">中文</a>
          </div>
        </div>
      </div>

      <button id="menu-toggle" class="xl:hidden relative z-50 w-8 h-10 flex flex-col justify-center items-end gap-[7px] focus:outline-none cursor-pointer md:pl-4" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobile-menu">
        <span id="line-1" class="block w-6 h-px bg-white transition-colors duration-300"></span>
        <span id="line-2" class="block w-4 h-px bg-white transition-colors duration-300"></span>
      </button>

    </div>
  </div>
</header>

<div id="mobile-menu" role="dialog" aria-modal="true" aria-label="Navigation menu" aria-hidden="true" class="fixed inset-0 z-40 bg-[#F2EFE9] flex flex-col items-center justify-center">
  <nav class="flex flex-col items-center gap-8">
    <a href="#concept"      class="mobile-link" style="--i:1">Concept</a>
    <a href="#floorplan"    class="mobile-link" style="--i:2">Masterplan</a>
    <a href="#gallery"      class="mobile-link" style="--i:3">Gallery</a>
    <a href="#area"         class="mobile-link" style="--i:4">Area</a>
    <div class="w-8 h-px bg-stone-300 my-1" aria-hidden="true"></div>
    <a href="#inquire"      class="mobile-link-cta" style="--i:5">Inquire</a>
    
    <div class="flex items-center gap-6 mt-6 mobile-lang" style="--i:6">
      <a href="/" class="font-sans text-xs font-medium tracking-[0.2em] text-stone-800 hover:text-stone-500 transition-colors">EN</a>
      <a href="#" class="font-sans text-xs font-light tracking-[0.2em] text-stone-400 hover:text-stone-800 transition-colors">JP</a>
      <a href="#" class="font-sans text-xs font-light tracking-[0.2em] text-stone-400 hover:text-stone-800 transition-colors">ZH</a>
    </div>
  </nav>
  <span class="absolute bottom-10 font-sans text-xs tracking-[0.2em] uppercase text-stone-400">
    Karuizawa &middot; Nagano &middot; Japan
  </span>
</div>

<style>
  #line-1, #line-2 {
    transform-origin: center;
    transition: transform 0.45s cubic-bezier(0.23, 1, 0.32, 1), width 0.3s cubic-bezier(0.23, 1, 0.32, 1), background-color 0.3s ease;
  }
  #menu-toggle.is-open #line-1 { transform: translateY(4px) rotate(-45deg); width: 1.5rem; }
  #menu-toggle.is-open #line-2 { transform: translateY(-4px) rotate(45deg); width: 1.5rem; }

  #mobile-menu {
    visibility: hidden; opacity: 0; pointer-events: none;
    transition: opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1), visibility 0s linear 0.45s;
  }
  #mobile-menu.is-open {
    visibility: visible; opacity: 1; pointer-events: auto;
    transition: opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1), visibility 0s linear 0s;
  }

  .mobile-link, .mobile-link-cta, .mobile-lang {
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.35s ease, transform 0.4s cubic-bezier(0.23, 1, 0.32, 1), color 0.25s ease, border-color 0.25s ease;
    transition-delay: 0s;
  }
  #mobile-menu.is-open .mobile-link, #mobile-menu.is-open .mobile-link-cta, #mobile-menu.is-open .mobile-lang {
    opacity: 1; transform: translateY(0);
    transition-delay: calc(0.07s + (var(--i) - 1) * 0.065s);
  }

  .mobile-link {
    font-family: var(--font-serif); font-size: clamp(2.25rem, 9vw, 3.75rem);
    font-weight: 300; letter-spacing: 0.015em; line-height: 1; color: #292524; text-decoration: none;
  }
  .mobile-link:hover { color: #a8a29e; }

  .mobile-link-cta {
    font-family: var(--font-sans); font-size: 0.65rem; font-weight: 500;
    letter-spacing: 0.22em; text-transform: uppercase; color: #292524; text-decoration: none;
    border-bottom: 1px solid #292524; padding-bottom: 3px;
  }
  .mobile-link-cta:hover { color: #78716c; border-color: #78716c; }
</style>

<script>
  const toggle       = document.getElementById('menu-toggle');
  const menu         = document.getElementById('mobile-menu');
  const desktopNav   = document.getElementById('desktop-nav');
  const logo         = document.getElementById('header-logo');
  const navLinks     = document.querySelectorAll('.nav-link');
  const langMenu     = document.getElementById('lang-menu');
  const line1        = document.getElementById('line-1');
  const line2        = document.getElementById('line-2');
  const header       = document.getElementById('main-header');
  
  const mobileLinks = menu ? Array.from(menu.querySelectorAll('a')) : [];
  const desktopLinks = desktopNav ? Array.from(desktopNav.querySelectorAll('a')) : [];
  const allLinks = [...mobileLinks, ...desktopLinks]; 
  
  let isOpen = false;

  // --- 1. PIXEL-PERFECT SCROLL & STATE LOGIC ---
  function updateHeaderState() {
    const hero = document.getElementById('hero-section');
    const headerHeight = header ? header.offsetHeight : 80;
    
    let isPastHero = false;

    if (hero) {
      isPastHero = hero.getBoundingClientRect().bottom <= (headerHeight + 10);
    } else {
      isPastHero = window.scrollY > 50;
    }

    // NEW LOGIC: Make text dark if scrolled past hero OR if the mobile menu is currently open
    const forceDark = isPastHero || isOpen;

    if (forceDark) {
      logo?.classList.remove('text-white');
      logo?.classList.add('text-stone-800');

      langMenu?.classList.remove('text-white');
      langMenu?.classList.add('text-stone-800');

      navLinks.forEach(link => {
        link.classList.remove('text-white/90', 'hover:text-white');
        link.classList.add('text-stone-500', 'hover:text-stone-800');
      });

      line1?.classList.remove('bg-white'); line1?.classList.add('bg-stone-800');
      line2?.classList.remove('bg-white'); line2?.classList.add('bg-stone-800');
      
    } else {
      logo?.classList.add('text-white');
      logo?.classList.remove('text-stone-800');

      langMenu?.classList.add('text-white');
      langMenu?.classList.remove('text-stone-800');

      navLinks.forEach(link => {
        link.classList.add('text-white/90', 'hover:text-white');
        link.classList.remove('text-stone-500', 'hover:text-stone-800');
      });

      line1?.classList.add('bg-white'); line1?.classList.remove('bg-stone-800');
      line2?.classList.add('bg-white'); line2?.classList.remove('bg-stone-800');
    }
  }

  window.addEventListener('scroll', updateHeaderState, { passive: true });
  window.addEventListener('resize', updateHeaderState, { passive: true });
  updateHeaderState(); 

  // --- 2. MENU TOGGLE & SCROLL ROUTING ---
  function lockScroll() {
    if (window['lenis']) window['lenis'].stop();
    document.body.style.overflow = 'hidden';
  }

  function unlockScroll() {
    document.body.style.overflow = '';
    if (window['lenis']) window['lenis'].start();
  }

  function openMenu() {
    isOpen = true;
    menu?.classList.add('is-open');
    toggle?.classList.add('is-open');
    toggle?.setAttribute('aria-expanded', 'true');
    menu?.setAttribute('aria-hidden', 'false');
    
    lockScroll();
    updateHeaderState(); // Force UI update immediately
  }

  function closeMenu() {
    if (!isOpen) return;
    isOpen = false;
    menu?.classList.remove('is-open');
    toggle?.classList.remove('is-open');
    toggle?.setAttribute('aria-expanded', 'false');
    menu?.setAttribute('aria-hidden', 'true');
    
    unlockScroll();
    updateHeaderState(); // Re-evaluate based on scroll position immediately
  }

  if (toggle) {
    toggle.addEventListener('click', () => { isOpen ? closeMenu() : openMenu(); });
  }

  allLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      const href = link.getAttribute('href');
      
      if (href && href.startsWith('#')) {
        e.preventDefault();
        
        const target = document.querySelector(href);
        if (target) {
          closeMenu();
          requestAnimationFrame(() => {
            const headerOffset = 0; 
            const lenisInstance = window['lenis']; 
            
            if (lenisInstance) {
              lenisInstance.scrollTo(target, { offset: headerOffset });
            } else {
              const elementPosition = target.getBoundingClientRect().top;
              const offsetPosition = elementPosition + window.scrollY - headerOffset;
              window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
            }
          });
        }
      } else {
        closeMenu();
      }
    });
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1280 && isOpen) closeMenu();
  });

  // --- 3. AUTO LANGUAGE REDIRECT LOGIC ---
  const hasVisited = localStorage.getItem('hc_lang_checked');
  if (!hasVisited) {
    localStorage.setItem('hc_lang_checked', 'true'); 
    
    const userLang = navigator.language.toLowerCase();
    
    /* Uncomment these lines when localized pages exist
    if (userLang.startsWith('ja') && window.location.pathname !== '/jp/') {
       window.location.href = '/jp/';
    } else if (userLang.startsWith('zh') && window.location.pathname !== '/zh/') {
       window.location.href = '/zh/';
    }
    */
  }
</script>