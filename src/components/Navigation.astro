---
// Navigation.astro - Minimalist Header with Full-Screen Mobile Overlay
---

<header class="w-full fixed top-0 left-0 z-50 bg-white/90 backdrop-blur-md border-b border-zinc-100">
  <div class="max-w-[100rem] mx-auto px-6 md:px-12 h-20 md:h-24 flex items-center justify-between">
    
    <a href="#" class="font-sans text-xs md:text-sm font-semibold tracking-[0.2em] uppercase text-zinc-800 transition-opacity hover:opacity-70 relative z-50">
      HC Property
    </a>

    <!-- Reverted to original gap-12 -->
    <nav class="hidden md:flex items-center gap-12" id="desktop-nav">
      <a href="#concept"      class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 hover:text-zinc-800 transition-colors duration-300">Concept</a>
      <a href="#architecture" class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 hover:text-zinc-800 transition-colors duration-300">Architecture</a>
      <a href="#gallery"      class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 hover:text-zinc-800 transition-colors duration-300">Gallery</a>
      <a href="#area"         class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 hover:text-zinc-800 transition-colors duration-300">Area</a>
      <a href="#inquire"      class="font-sans text-xs font-medium tracking-[0.2em] uppercase text-zinc-400 hover:text-zinc-800 transition-colors duration-300">Inquire</a>
    </nav>

    <button id="menu-toggle" class="md:hidden relative z-50 w-10 h-10 flex flex-col justify-center items-end gap-[7px] focus:outline-none cursor-pointer" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobile-menu">
      <span id="line-1" class="block w-6 h-px bg-zinc-800"></span>
      <span id="line-2" class="block w-4 h-px bg-zinc-800"></span>
    </button>
  </div>
</header>

<div id="mobile-menu" role="dialog" aria-modal="true" aria-label="Navigation menu" aria-hidden="true" class="fixed inset-0 z-40 bg-white flex flex-col items-center justify-center">
  <!-- Reverted to original gap-8 -->
  <nav class="flex flex-col items-center gap-8">
    <a href="#concept"      class="mobile-link" style="--i:1">Concept</a>
    <a href="#architecture" class="mobile-link" style="--i:2">Architecture</a>
    <a href="#gallery"      class="mobile-link" style="--i:3">Gallery</a>
    <a href="#area"         class="mobile-link" style="--i:4">Area</a>
    <div class="w-8 h-px bg-zinc-200 my-1" aria-hidden="true"></div>
    <a href="#inquire"      class="mobile-link-cta" style="--i:5">Inquire</a>
  </nav>
  <span class="absolute bottom-10 font-sans text-xs tracking-[0.2em] uppercase text-zinc-300">
    Kutchan &middot; Hokkaido &middot; Japan
  </span>
</div>

<style>
  #line-1, #line-2 {
    transform-origin: center;
    transition: transform 0.45s cubic-bezier(0.23, 1, 0.32, 1), width 0.3s cubic-bezier(0.23, 1, 0.32, 1), background-color 0.3s ease;
  }
  #menu-toggle.is-open #line-1 { transform: translateY(4px) rotate(-45deg); width: 1.5rem; }
  #menu-toggle.is-open #line-2 { transform: translateY(-4px) rotate(45deg); width: 1.5rem; }

  #mobile-menu {
    visibility: hidden; opacity: 0; pointer-events: none;
    transition: opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1), visibility 0s linear 0.45s;
  }
  #mobile-menu.is-open {
    visibility: visible; opacity: 1; pointer-events: auto;
    transition: opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1), visibility 0s linear 0s;
  }

  .mobile-link, .mobile-link-cta {
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.35s ease, transform 0.4s cubic-bezier(0.23, 1, 0.32, 1), color 0.25s ease, border-color 0.25s ease;
    transition-delay: 0s;
  }
  #mobile-menu.is-open .mobile-link, #mobile-menu.is-open .mobile-link-cta {
    opacity: 1; transform: translateY(0);
    transition-delay: calc(0.07s + (var(--i) - 1) * 0.065s);
  }

  .mobile-link {
    font-family: var(--font-serif); font-size: clamp(2.25rem, 9vw, 3.75rem);
    font-weight: 300; letter-spacing: 0.015em; line-height: 1; color: #27272a; text-decoration: none;
  }
  .mobile-link:hover { color: #a1a1aa; }

  .mobile-link-cta {
    font-family: var(--font-sans); font-size: 0.65rem; font-weight: 500;
    letter-spacing: 0.22em; text-transform: uppercase; color: #27272a; text-decoration: none;
    border-bottom: 1px solid #27272a; padding-bottom: 3px;
  }
  .mobile-link-cta:hover { color: #71717a; border-color: #71717a; }
</style>

<script>
  const toggle     = document.getElementById('menu-toggle');
  const menu       = document.getElementById('mobile-menu');
  const desktopNav = document.getElementById('desktop-nav');
  
  const mobileLinks = menu ? Array.from(menu.querySelectorAll('a')) : [];
  const desktopLinks = desktopNav ? Array.from(desktopNav.querySelectorAll('a')) : [];
  const allLinks = [...mobileLinks, ...desktopLinks];
  
  let isOpen = false;

  function lockScroll() {
    if (window['lenis']) window['lenis'].stop();
    document.body.style.overflow = 'hidden';
  }

  function unlockScroll() {
    document.body.style.overflow = '';
    if (window['lenis']) window['lenis'].start();
  }

  function openMenu() {
    isOpen = true;
    menu?.classList.add('is-open');
    toggle?.classList.add('is-open');
    toggle?.setAttribute('aria-expanded', 'true');
    menu?.setAttribute('aria-hidden', 'false');
    lockScroll();
  }

  function closeMenu() {
    if (!isOpen) return;
    isOpen = false;
    menu?.classList.remove('is-open');
    toggle?.classList.remove('is-open');
    toggle?.setAttribute('aria-expanded', 'false');
    menu?.setAttribute('aria-hidden', 'true');
    unlockScroll();
  }

  if (toggle) {
    toggle.addEventListener('click', () => { isOpen ? closeMenu() : openMenu(); });
  }

  allLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      const href = link.getAttribute('href');
      
      if (href && href.startsWith('#')) {
        e.preventDefault();
        
        const target = document.querySelector(href);
        if (target) {
          closeMenu();
          
          requestAnimationFrame(() => {
            const headerOffset = 96; 
            const lenisInstance = window['lenis']; 
            
            if (lenisInstance) {
              lenisInstance.scrollTo(target, { offset: -headerOffset });
            } else {
              const elementPosition = target.getBoundingClientRect().top;
              const offsetPosition = elementPosition + window.scrollY - headerOffset;
              window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
            }
          });
        }
      } else {
        closeMenu();
      }
    });
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768 && isOpen) closeMenu();
  });
</script>