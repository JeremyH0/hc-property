---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
    images: ImageMetadata[];
}

const { images } = Astro.props;
// Generate a unique ID to safely scope JS and identify the carousel
const carouselId = Math.random().toString(36).substring(7);
---

<smooth-carousel class="block relative w-full group select-none" data-carousel-id={carouselId}>
    <!-- Main Carousel Container -->
    <div class="carousel-main relative w-full aspect-[4/3] xl:aspect-[3/2] rounded-xl overflow-hidden bg-zinc-50 border border-zinc-200 shadow-sm cursor-pointer">
        
        {images.map((img, index) => (
            <div class="carousel-slide absolute inset-0 w-full h-full transition-opacity duration-700 ease-in-out" data-index={index} style={{ opacity: index === 0 ? '1' : '0', zIndex: index === 0 ? '10' : '0' }}>
                <Image src={img} alt={`Slide ${index + 1}`} class="w-full h-full object-cover pointer-events-none" />
            </div>
        ))}

        <div class="absolute inset-0 bg-gradient-to-t from-zinc-900/30 via-transparent to-zinc-900/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-20 pointer-events-none"></div>

        <button class="prev-btn absolute left-4 top-1/2 -translate-y-1/2 z-30 w-10 h-10 md:w-12 md:h-12 rounded-full border border-white/20 bg-zinc-900/40 backdrop-blur-md hidden md:flex items-center justify-center text-white transition-all duration-300 hover:bg-zinc-900/80 hover:scale-105 opacity-0 group-hover:opacity-100 cursor-pointer" aria-label="Previous image">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
            </svg>
        </button>

        <button class="next-btn absolute right-4 top-1/2 -translate-y-1/2 z-30 w-10 h-10 md:w-12 md:h-12 rounded-full border border-white/20 bg-zinc-900/40 backdrop-blur-md hidden md:flex items-center justify-center text-white transition-all duration-300 hover:bg-zinc-900/80 hover:scale-105 opacity-0 group-hover:opacity-100 cursor-pointer" aria-label="Next image">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7" />
            </svg>
        </button>
        
        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 z-30 flex gap-2 pointer-events-auto">
            {images.map((_, index) => (
                <button class={`dot-btn w-2 h-2 rounded-full transition-all duration-300 cursor-pointer ${index === 0 ? 'bg-white scale-125' : 'bg-white/50 hover:bg-white/80'}`} data-index={index} aria-label={`Go to slide ${index + 1}`}></button>
            ))}
        </div>
    </div>
</smooth-carousel>

<script>
    class SmoothCarousel extends HTMLElement {
        connectedCallback() {
            const mainContainer = this.querySelector('.carousel-main');
            const slides = Array.from(this.querySelectorAll('.carousel-slide')) as HTMLElement[];
            const dots = Array.from(this.querySelectorAll('.dot-btn')) as HTMLButtonElement[];
            const prevBtn = this.querySelector('.prev-btn');
            const nextBtn = this.querySelector('.next-btn');
            
            // Get the unique ID for this specific carousel instance
            const carouselId = this.getAttribute('data-carousel-id');

            if (!mainContainer || slides.length === 0) return;

            let currentIndex = 0;
            let isAnimating = false;
            const totalSlides = slides.length;

            const imageUrls = slides.map(slide => {
                const img = slide.querySelector('img');
                return img ? img.src : '';
            });

            // Added a "forceSync" parameter to bypass animation locks when controlled by the lightbox
            const goToSlide = (index: number, forceSync = false) => {
                if (!forceSync && (isAnimating || index === currentIndex)) return;
                if (forceSync && index === currentIndex) return; 
                
                isAnimating = true;

                slides[currentIndex].style.opacity = '0';
                slides[currentIndex].style.zIndex = '0';
                dots[currentIndex].classList.remove('bg-white', 'scale-125');
                dots[currentIndex].classList.add('bg-white/50');

                currentIndex = index;

                slides[currentIndex].style.opacity = '1';
                slides[currentIndex].style.zIndex = '10';
                dots[currentIndex].classList.add('bg-white', 'scale-125');
                dots[currentIndex].classList.remove('bg-white/50');

                // Instant sync if controlled by lightbox, otherwise standard 700ms fade
                setTimeout(() => { isAnimating = false; }, forceSync ? 50 : 700);
            };

            const nextSlide = () => goToSlide((currentIndex + 1) % totalSlides);
            const prevSlide = () => goToSlide((currentIndex - 1 + totalSlides) % totalSlides);

            nextBtn?.addEventListener('click', (e) => { e.stopPropagation(); nextSlide(); });
            prevBtn?.addEventListener('click', (e) => { e.stopPropagation(); prevSlide(); });
            dots.forEach((dot, idx) => {
                dot.addEventListener('click', (e) => { e.stopPropagation(); goToSlide(idx); });
            });

            let touchStartX = 0;
            let touchEndX = 0;
            mainContainer.addEventListener('touchstart', (e: TouchEvent) => {
                touchStartX = e.changedTouches[0].screenX;
            }, { passive: true });
            
            mainContainer.addEventListener('touchend', (e: TouchEvent) => {
                touchEndX = e.changedTouches[0].screenX;
                const threshold = 40;
                if (e.touches.length > 0) return; 

                if (touchStartX - touchEndX > threshold) {
                    nextSlide();
                } else if (touchEndX - touchStartX > threshold) {
                    prevSlide();
                }
            }, { passive: true });

            // Send the carousel ID (source) to the lightbox when opening
            mainContainer.addEventListener('click', (e) => {
                if ((e.target as HTMLElement).tagName !== 'BUTTON' && Math.abs(touchStartX - touchEndX) < 10) {
                    window.dispatchEvent(new CustomEvent('open-carousel-lightbox', {
                        detail: { 
                            images: imageUrls,
                            currentIndex: currentIndex,
                            source: carouselId // Identity attached here!
                        }
                    }));
                }
                touchStartX = 0; touchEndX = 0;
            });

            // Listen for global sync events from the Lightbox
            window.addEventListener('lightbox-image-changed', (e: any) => {
                if (e.detail.source === carouselId) {
                    goToSlide(e.detail.index, true); // Force background sync
                }
            });
        }
    }
    customElements.define('smooth-carousel', SmoothCarousel);
</script>