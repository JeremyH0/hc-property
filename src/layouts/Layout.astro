---
import '../styles/global.css';

interface Props {
    title: string;
    description?: string;
}

const { title, description = "Luxury Property Real Estate" } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
        
        <title>{title}</title>

        <style is:global>
            /* Lenis Core Setup */
            html.lenis, html.lenis body { height: auto; }
            .lenis.lenis-smooth { scroll-behavior: auto !important; }
            .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
            .lenis.lenis-stopped { overflow: hidden; }

            /* Hardware-Accelerated Reveal States */
            .reveal-el {
                opacity: 0;
                transform: translate3d(0, 40px, 0);
                transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
                will-change: opacity, transform;
                backface-visibility: hidden;
                perspective: 1000px;
            }
            .hero-reveal {
                opacity: 0;
                transform: translate3d(0, 30px, 0);
                transition: opacity 1s cubic-bezier(0.25, 1, 0.5, 1), transform 1s cubic-bezier(0.25, 1, 0.5, 1);
                will-change: opacity, transform;
                backface-visibility: hidden;
                perspective: 1000px;
            }
            .is-revealed {
                opacity: 1 !important;
                transform: translate3d(0, 0, 0) !important;
            }
        </style>
    </head>
    
    <body class="bg-[#F4F4F5] text-zinc-800 font-sans antialiased selection:bg-zinc-200 selection:text-zinc-900 lg:cursor-none">
        
        <div id="preloader" class="fixed inset-0 z-[10000] bg-[#E4E4E7] flex items-center justify-center transition-transform duration-[1200ms] ease-[cubic-bezier(0.7,0,0.3,1)]">
            <div id="preloader-text" class="font-sans text-xs md:text-sm font-medium tracking-[0.4em] uppercase text-zinc-800 transition-all duration-700 ease-out translate-y-0 opacity-100">
                HIRAFU CAPITAL GK
            </div>
        </div>

        <div id="custom-cursor" class="hidden lg:block fixed top-0 left-0 w-12 h-12 bg-white rounded-full pointer-events-none z-[9999] mix-blend-difference will-change-transform" style="transform: translate3d(0px, 0px, 0px) translate(-50%, -50%) scale(0.25);"></div>

        <slot />

        <script is:inline src="https://unpkg.com/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>

        <script is:inline>
            document.addEventListener('DOMContentLoaded', () => {
                
                // --- 1. LENIS CONFIGURATION ---
                const lenis = new window.Lenis({ 
                    lerp: 0.08,
                    wheelMultiplier: 1.0, 
                    smoothWheel: true,
                    syncTouch: false 
                });
                lenis.stop(); // Pause scroll during preloader
                window.lenis = lenis; 

                function raf(time) { 
                    lenis.raf(time); 
                    requestAnimationFrame(raf); 
                }
                requestAnimationFrame(raf);

                // --- 2. PRELOADER TIMING ---
                const preloader = document.getElementById('preloader');
                const preloaderText = document.getElementById('preloader-text');

                // Fade out text
                setTimeout(() => {
                    if (preloaderText) { 
                        preloaderText.style.opacity = '0'; 
                        preloaderText.style.transform = 'translate3d(0, -15px, 0)'; 
                    }
                }, 1000);

                // Slide up curtain & trigger hero reveals
                setTimeout(() => {
                    if (preloader) preloader.style.transform = 'translate3d(0, -100%, 0)';
                    const heroElements = document.querySelectorAll('.hero-reveal');
                    heroElements.forEach((el, index) => {
                        setTimeout(() => { el.classList.add('is-revealed'); }, index * 150);
                    });
                }, 1600);

                // Unlock scroll and destroy preloader element
                setTimeout(() => {
                    lenis.start();
                    if (preloader) preloader.remove();
                }, 2800);

                // --- 3. HIGH-PERFORMANCE SCROLL REVEAL ---
                // Optimized to only add the class. Removed heavy bounding box checks.
                const revealObserver = new IntersectionObserver((entries, observer) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            requestAnimationFrame(() => { 
                                entry.target.classList.add('is-revealed'); 
                            });
                            observer.unobserve(entry.target); // Stop tracking once revealed
                        }
                    });
                }, { rootMargin: '0px 0px -5% 0px', threshold: 0 });
                
                document.querySelectorAll('.reveal-el').forEach(el => { revealObserver.observe(el); });

                // --- 4. CUSTOM CURSOR ---
                const cursor = document.getElementById('custom-cursor');
                if (window.matchMedia("(pointer: fine)").matches && cursor) {
                    let mouseX = window.innerWidth / 2; let mouseY = window.innerHeight / 2;
                    let cursorX = mouseX; let cursorY = mouseY;
                    let currentScale = 0.25; let targetScale = 0.25;
                    
                    window.addEventListener('mousemove', (e) => { 
                        mouseX = e.clientX; 
                        mouseY = e.clientY; 
                    }, { passive: true });

                    function updateCursor() {
                        currentScale += (targetScale - currentScale) * 0.15;
                        cursorX += (mouseX - cursorX) * 0.4; cursorY += (mouseY - cursorY) * 0.4;
                        
                        // Use toFixed to prevent layout thrashing from overly long decimal strings
                        if (cursor) {
                            cursor.style.transform = `translate3d(${cursorX.toFixed(2)}px, ${cursorY.toFixed(2)}px, 0) translate(-50%, -50%) scale(${currentScale.toFixed(3)})`;
                        }
                        requestAnimationFrame(updateCursor);
                    }
                    requestAnimationFrame(updateCursor);

                    // Added specific targets for our new UI elements (.floorplan-trigger, .gallery-thumb)
                    const interactables = document.querySelectorAll('a, button, input, textarea, .floorplan-trigger, .gallery-thumb, #menu-toggle');
                    interactables.forEach(el => {
                        el.addEventListener('mouseenter', () => { targetScale = 1; });
                        el.addEventListener('mouseleave', () => { targetScale = 0.25; });
                    });
                }
            });
        </script>
    </body>
</html>